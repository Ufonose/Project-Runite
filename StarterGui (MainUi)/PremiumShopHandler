		local function checkCard4MaxStatus()
			local ok, upgradesData, playerUpgrades = pcall(function()
				local ud = RepStorage.Events.GetUpgradesData:InvokeServer()
				local pu = RepStorage.Events.GetPlayerUpgrades:InvokeServer()
				return ud, pu
			end)
			if ok and upgradesData and playerUpgrades then
				allMaxedByGrind = true
				for upgradeId, upgradeData in pairs(upgradesData) do
					local lvl = playerUpgrades[upgradeId] or 0
					if lvl < (upgradeData.MaxLevel or 10) then
						allMaxedByGrind = false
						break
					end
				end
			end
			refreshCard4()
		end

		-- Expose so UpgradeShopHandler can notify us after any cash purchase
		_G.NotifyPremiumShopUpgradePurchased = checkCard4MaxStatus

		-- Max All: green if owned OR if every upgrade is already maxed by grinding
		refreshCard4 = function()
			local isMaxed = owned4 or allMaxedByGrind
			refreshCard(card4, isMaxed,
				Color3.fromRGB(25, 45, 25), Color3.fromRGB(50, 180, 80),
				Color3.fromRGB(35, 20, 10),  Color3.fromRGB(220, 100, 30))
			if isMaxed then
				card4.ownedBadge.Text             = "✓ Maxed"
				card4.ownedBadge.TextColor3       = Color3.fromRGB(120, 255, 140)
				card4.ownedBadge.BackgroundColor3 = Color3.fromRGB(30, 100, 40)
			end
		end

		local function checkCard5ResearchStatus()
			local ok, data = pcall(function()
				return RepStorage.Events.GetSpeedrunData:InvokeServer()
			end)
			if ok and data then
				-- GetData returns Unlocked=true once all research objectives are done
				allResearchComplete = data.Unlocked == true
			end
		end

		local refreshCard5  -- forward declaration so checkCard5ResearchStatus can call it

		refreshCard5 = function()
			local isUnlocked = owned5 or allResearchComplete
			refreshCard(card5, isUnlocked,
				Color3.fromRGB(25, 45, 25), Color3.fromRGB(50, 180, 80),
				Color3.fromRGB(25, 20, 40),  Color3.fromRGB(160, 80, 255))
			if isUnlocked then
				card5.ownedBadge.Text             = "✓ Unlocked"
				card5.ownedBadge.TextColor3       = Color3.fromRGB(120, 255, 140)
				card5.ownedBadge.BackgroundColor3 = Color3.fromRGB(30, 100, 40)
			end
		end

		-- Expose so ResearchHandler/SpeedrunHandler can notify us when research finishes
		_G.NotifyPremiumShopResearchCompleted = function()
			allResearchComplete = true
			if premiumContainer.Visible then refreshCard5() end
		end

		local function checkOwnership()
			if checked1 and checked2 and checked3 and checked4 and checked5 then
				task.spawn(function()
					local getSpeedrunData = RepStorage.Events:FindFirstChild("GetSpeedrunData")
					if getSpeedrunData then
						local ok, data = pcall(function() return getSpeedrunData:InvokeServer() end)
						if ok and data then
							IN_SPEEDRUN = data.InSpeedrunMode == true or data.IsActive == true
						end
					end
					refreshCard1()
					refreshCard2()
					refreshCard3()
					refreshCard4()
					refreshCard5()
				end)
				return
			end

			task.spawn(function()
				local checkRemote = RepStorage.Events:WaitForChild("CheckGamepassOwned", 5)
				if not checkRemote then return end

				if not checked1 then
					local ok, result = pcall(function()
						return checkRemote:InvokeServer(DOUBLE_CASH_GAMEPASS_ID)
					end)
					if ok then owned1 = result == true; checked1 = true end
					refreshCard1()
				end

				if not checked2 then
					local ok, result = pcall(function()
						return checkRemote:InvokeServer(AUTO_RESEARCH_GAMEPASS_ID)
					end)
					if ok then owned2 = result == true; checked2 = true end
					refreshCard2()
				end

				if not checked3 then
					local ok, result = pcall(function()
						return checkRemote:InvokeServer(RESEARCH_BOOST_GAMEPASS_ID)
					end)
					if ok then owned3 = result == true; checked3 = true end
				end

				if not checked4 then
					local ok, result = pcall(function()
						return checkRemote:InvokeServer(MAX_ALL_UPGRADES_GAMEPASS_ID)
					end)
					if ok then owned4 = result == true; checked4 = true end
				end

				if not checked5 then
					local ok, result = pcall(function()
						return checkRemote:InvokeServer(SPEEDRUN_EARLY_ACCESS_GAMEPASS_ID)
					end)
					if ok then owned5 = result == true; checked5 = true end
				end

				-- Check if all upgrades are already maxed by grinding
				checkCard4MaxStatus()

				-- Check if all research is complete (unlocks card5 for free)
				checkCard5ResearchStatus()
				refreshCard5()

				local getSpeedrunData = RepStorage.Events:FindFirstChild("GetSpeedrunData")
				if getSpeedrunData then
					local ok2, data = pcall(function() return getSpeedrunData:InvokeServer() end)
					if ok2 and data then
						IN_SPEEDRUN = data.InSpeedrunMode == true or data.IsActive == true
					end
				end
				refreshCard3()
			end)
		end

		-- Buy buttons
		card1.buyBtn.MouseButton1Click:Connect(function()
			MarketplaceService:PromptGamePassPurchase(Plr, DOUBLE_CASH_GAMEPASS_ID)
		end)

		card2.buyBtn.MouseButton1Click:Connect(function()
			MarketplaceService:PromptGamePassPurchase(Plr, AUTO_RESEARCH_GAMEPASS_ID)
		end)

		card3.buyBtn.MouseButton1Click:Connect(function()
			MarketplaceService:PromptGamePassPurchase(Plr, RESEARCH_BOOST_GAMEPASS_ID)
		end)

		card4.buyBtn.MouseButton1Click:Connect(function()
			MarketplaceService:PromptGamePassPurchase(Plr, MAX_ALL_UPGRADES_GAMEPASS_ID)
		end)

		card5.buyBtn.MouseButton1Click:Connect(function()
			MarketplaceService:PromptGamePassPurchase(Plr, SPEEDRUN_EARLY_ACCESS_GAMEPASS_ID)
		end)

		-- Listen for purchases to refresh UI without reopening the shop
		local purchasedEvent = RepStorage.Events:WaitForChild("GamepassPurchased", 5)
		if purchasedEvent then
			purchasedEvent.OnClientEvent:Connect(function(gpName)
				if gpName == "DoubleCash" then
					owned1 = true; checked1 = true
					if premiumContainer.Visible then refreshCard1() end
				elseif gpName == "AutoResearch" then
					owned2 = true; checked2 = true
					if premiumContainer.Visible then refreshCard2() end
				elseif gpName == "ResearchBoost" then
					owned3 = true; checked3 = true
					if premiumContainer.Visible then refreshCard3() end
				elseif gpName == "MaxAllUpgrades" then
					owned4 = true; checked4 = true
					if premiumContainer.Visible then refreshCard4() end
				elseif gpName == "SpeedrunEarlyAccess" then
					owned5 = true; checked5 = true
					if premiumContainer.Visible then refreshCard5() end
				end
			end)
		end

		-- Refresh card4 after any dev product "Instant Max" purchase
		MarketplaceService.PromptProductPurchaseFinished:Connect(function(_, _, wasPurchased)
			if wasPurchased then
				task.spawn(checkCard4MaxStatus)
			end
		end)

		-- ==================== SPEEDRUN LISTENERS ====================
		local Events = RepStorage:WaitForChild("Events")

		Events:WaitForChild("EnteredSpeedrunMode").OnClientEvent:Connect(function()
			IN_SPEEDRUN = true
			refreshCard3()
		end)
		Events:WaitForChild("SpeedrunStarted").OnClientEvent:Connect(function()
			IN_SPEEDRUN = true
			refreshCard3()
		end)
		Events:WaitForChild("RestoredMainPlot").OnClientEvent:Connect(function()
			IN_SPEEDRUN = false
			refreshCard3()
		end)
		Events:WaitForChild("AllResearchCompleted").OnClientEvent:Connect(function()
			checkCard5ResearchStatus()  -- re-verify from server rather than assuming true
		end)

		-- ==================== TAB SWITCHING ====================
		premiumTabButton.MouseButton1Click:Connect(function()
			local itemsTabBtn    = tabButtonsBackground:FindFirstChild("ItemsTab")
			local upgradesTabBtn = tabButtonsBackground:FindFirstChild("UpgradesTab")
			if itemsTabBtn    then itemsTabBtn.BackgroundColor3    = Color3.fromRGB(40, 40, 45) end
			if upgradesTabBtn then upgradesTabBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 45) end
			premiumTabButton.BackgroundColor3 = Color3.fromRGB(160, 110, 0)

			local ic = shopFrame:FindFirstChild("ItemsContainer")
			if ic then ic.Visible = false end
			local uc = shopFrame:FindFirstChild("UpgradesContainer")
			if uc then uc.Visible = false end

			premiumContainer.Visible = true
			checkOwnership()
		end)

		-- Hide PremiumContainer when other tabs are clicked
		local upgradesTabBtn = tabButtonsBackground:WaitForChild("UpgradesTab", 10)
		if upgradesTabBtn then
			upgradesTabBtn.MouseButton1Click:Connect(function()
				premiumContainer.Visible = false
				premiumTabButton.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
			end)
		end

		local itemsTabBtn = tabButtonsBackground:WaitForChild("ItemsTab", 10)
		if itemsTabBtn then
			itemsTabBtn.MouseButton1Click:Connect(function()
				premiumContainer.Visible = false
				premiumTabButton.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
			end)
		end

	end) -- end task.spawn
end

return module
