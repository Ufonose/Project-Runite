-- StarterPlayerScripts/LocalConveyorManager.lua
local RunService = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Localization
local Vector3_new = Vector3.new
local CFrame_new = CFrame.new
local CFrame_Angles = CFrame.Angles
local math_rad = math.rad
local math_sin = math.sin
local math_cos = math.cos
local math_abs = math.abs
local os_clock = os.clock
local math_lerp = function(a, b, t) return a + (b - a) * t end

local localPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local RAY_CAST_DISTANCE = 4
local DEFAULT_SPEED     = 7
local EDGE_BUFFER       = 0.8
local RAY_DIRECTION     = Vector3_new(0, -RAY_CAST_DISTANCE, 0)

-- PERFORMANCE SETTINGS
local DETAILED_DIST = 80

-- LIFE-LIKE SETTINGS
local VIBRATION_INTENSITY = 0.03
local ROTATION_SPEED      = 0.5
local WOBBLE_STRENGTH     = 5

-- STUCK DETECTION SETTINGS
local STUCK_THRESHOLD  = 10   -- seconds without movement before deleting
local STUCK_CHECK_RATE = 3    -- how often (seconds) to sample position
local STUCK_EPSILON    = 0.5  -- studs; less than this counts as not moved

-- Remote to ask the server to destroy the ore
local StuckOreEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("DestroyStuckOre")

-- ── Ore cache ────────────────────────────────────────────────────────────────
local trackedOres = {}
local oreData     = {}

local function onOreAdded(ore)
	-- Walk up to find the plot owner; skip ores that don't belong to us
	local current = ore.Parent
	while current and current ~= workspace do
		if current.Name == "OresDropped" then
			local plot = current.Parent and current.Parent.Parent -- OresDropped → MiscInfo → Plot
			if plot then
				local ownerVal = plot:FindFirstChild("Owner")
				if ownerVal and ownerVal.Value ~= localPlayer.Name then
					-- Hide it and don't track it — saves the entire Heartbeat cost
					for _, part in ipairs(ore:GetDescendants()) do
						if part:IsA("BasePart") or part:IsA("Decal") then
							part.Transparency = 1
						end
					end
					if ore:IsA("BasePart") then ore.Transparency = 1 end
					return
				end
			end
			break
		end
		current = current.Parent
	end

	trackedOres[ore] = true
	oreData[ore] = {
		seed        = ore:GetAttribute("OreID") or 0,
		laneOffset  = ore:GetAttribute("LaneOffset") or 0,
		baseRotV3   = ore:GetAttribute("BaseRotation") or Vector3_new(0, 0, 0),
		lastPos     = ore.Position,
		stuckTimer  = 0,
		lastCheck   = os_clock(),
	}
end

local function onOreRemoved(ore)
	trackedOres[ore] = nil
	oreData[ore]     = nil
end

CollectionService:GetInstanceAddedSignal("MovingOre"):Connect(onOreAdded)
CollectionService:GetInstanceRemovedSignal("MovingOre"):Connect(onOreRemoved)

for _, ore in ipairs(CollectionService:GetTagged("MovingOre")) do
	onOreAdded(ore)
end

local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Exclude

local filteredInstances = {}
for _, plot in ipairs(workspace.Plots:GetChildren()) do
	local folder = plot:FindFirstChild("OresDropped")
	if folder then
		table.insert(filteredInstances, folder)
	end
end

-- Exclude local character from raycasts
if localPlayer.Character then
	table.insert(filteredInstances, localPlayer.Character)
end
localPlayer.CharacterAdded:Connect(function(character)
	table.insert(filteredInstances, character)
	rayParams.FilterDescendantsInstances = filteredInstances
end)

rayParams.FilterDescendantsInstances = filteredInstances

-- ── MAIN LOOP ────────────────────────────────────────────────────────────────
RunService.Heartbeat:Connect(function(dt)
	local timeTime = os_clock()
	local camPos   = Camera.CFrame.Position

	for ore in pairs(trackedOres) do
		if not ore or not ore.Parent then trackedOres[ore] = nil oreData[ore] = nil continue end

		local data        = oreData[ore]
		local orePos      = ore.Position
		local distFromCam = (orePos - camPos).Magnitude

		-- 1. RAYCAST (Using static RAY_DIRECTION)
		local result = workspace:Raycast(orePos, RAY_DIRECTION, rayParams)

		-- Edge fallback for corners
		if not result and ore.Anchored then
			local moveDir = ore.AssemblyLinearVelocity.Magnitude > 0.1
				and ore.AssemblyLinearVelocity.Unit
				or ore.CFrame.LookVector
			local r = workspace:Raycast(orePos - (moveDir * EDGE_BUFFER), RAY_DIRECTION, rayParams)
			if r and r.Instance and (r.Instance.Name:find("Conv") or r.Instance.Name == "SideStuck") then
				result = r
			end
		end

		if result and result.Instance and (result.Instance.Name:find("Conv") or result.Instance.Name == "SideStuck") then
			local part = result.Instance

			-- If we landed on a SideStuck, redirect to nearest Conv in the same item
			if part.Name == "SideStuck" then
				local model = part.Parent
				while model and not (model:IsA("Model") and model:FindFirstChild("Hitbox")) do
					model = model.Parent
				end
				if model then
					local nearest, nearestDist = nil, math.huge
					for _, desc in ipairs(model:GetDescendants()) do
						if desc:IsA("BasePart") and desc.Name == "Conv" then
							local d = (desc.Position - orePos).Magnitude
							if d < nearestDist then nearestDist = d; nearest = desc end
						end
					end
					if nearest then part = nearest end
				end
			end

			local isReversed = part:GetAttribute("ConveyorReversed")
				or (part.Parent and part.Parent:GetAttribute("ConveyorReversed"))
			local multiplier = (isReversed == true) and -1 or 1

			local convVeloPart = part:FindFirstChild("ConvVelo")
			local speed        = convVeloPart and convVeloPart.Value or DEFAULT_SPEED
			local finalSpeed   = speed * multiplier
			local actualMoveVec = part.CFrame.LookVector * (finalSpeed * dt)

			if not ore.Anchored and math_abs(ore.AssemblyLinearVelocity.Y) < 15 then
				ore.Anchored = true
			end

			if ore.Anchored then
				local relPos     = part.CFrame:PointToObjectSpace(orePos)
				local targetRelX = math_lerp(relPos.X, data.laneOffset, 0.2)
				local baseRotCF  = CFrame_Angles(math_rad(data.baseRotV3.X), math_rad(data.baseRotV3.Y), math_rad(data.baseRotV3.Z))

				local finalRotation, targetRelY

				if distFromCam > DETAILED_DIST then
					targetRelY    = (part.Size.Y * 0.5) + (ore.Size.Y * 0.5)
					finalRotation = baseRotCF
				else
					local seed    = data.seed
					local jitterY = math_sin(timeTime * 25 + seed) * VIBRATION_INTENSITY
					local wobbleX = math_sin(timeTime * 6  + seed) * math_rad(WOBBLE_STRENGTH)
					local wobbleZ = math_cos(timeTime * 7  + seed) * math_rad(WOBBLE_STRENGTH)
					local spinY   = (timeTime * ROTATION_SPEED + seed) % (math.pi * 2)

					targetRelY    = (part.Size.Y * 0.5) + (ore.Size.Y * 0.5) + jitterY
					finalRotation = baseRotCF * CFrame_Angles(wobbleX, spinY, wobbleZ)
				end

				ore.CFrame = (part.CFrame:ToWorldSpace(CFrame_new(targetRelX, targetRelY, relPos.Z)) * finalRotation) + actualMoveVec
				ore.AssemblyLinearVelocity = part.CFrame.LookVector * finalSpeed
			else
				ore.AssemblyLinearVelocity = part.CFrame.LookVector * finalSpeed
			end
		else
			-- Fall off logic
			if ore.Anchored then
				ore.Anchored = false
				local exitVelocity = ore.AssemblyLinearVelocity
				if exitVelocity.Magnitude < 1 then
					exitVelocity = ore.CFrame.LookVector * DEFAULT_SPEED
				end
				ore.AssemblyLinearVelocity = exitVelocity * 1.2
			end
		end

		-- ── STUCK DETECTION ──────────────────────────────────────────────────
		if timeTime - data.lastCheck >= STUCK_CHECK_RATE then
			local distMoved = (ore.Position - data.lastPos).Magnitude

			if distMoved < STUCK_EPSILON then
				data.stuckTimer = data.stuckTimer + STUCK_CHECK_RATE
				if data.stuckTimer >= STUCK_THRESHOLD then
					-- Remove from tracking immediately to prevent duplicate fires
					trackedOres[ore] = nil
					oreData[ore]     = nil
					StuckOreEvent:FireServer(ore)
					continue -- skip the rest of this iteration
				end
			else
				data.stuckTimer = 0
			end

			data.lastPos   = ore.Position
			data.lastCheck = timeTime
		end
		-- ─────────────────────────────────────────────────────────────────────
	end
end)
