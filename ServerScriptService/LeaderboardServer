-- ServerScriptService/LeaderboardServer
local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")

local leaderboardPart = workspace:WaitForChild("Leaderboards"):WaitForChild("Leaderboard") -- adjust path

