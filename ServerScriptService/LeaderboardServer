-- ── SUFFIX ────────────────────────────────────────────────────────────────
local function suffixNum(n)
	if n >= 1e12 then return string.format("$%.1fT", n / 1e12)
	elseif n >= 1e9  then return string.format("$%.1fB", n / 1e9)
	elseif n >= 1e6  then return string.format("$%.1fM", n / 1e6)
	elseif n >= 1e3  then return string.format("$%.1fK", n / 1e3)
	else return "$" .. math.floor(n) end
end

-- ── SAVE TO ORDERED DS ────────────────────────────────────────────────────
local saveCooldowns = {}

local function saveToOrderedStore(player, force)
	local te = player:FindFirstChild("TotalEarned")
	if not te or te.Value <= 0 then return end

	local now = os.time()
	if not force then
		if saveCooldowns[player.UserId] and now - saveCooldowns[player.UserId] < 60 then return end
	end
	saveCooldowns[player.UserId] = now

	pcall(function()
		EarnedStore:SetAsync(tostring(player.UserId), math.floor(te.Value))
	end)
end

local activeLoops = {}

local function hookPlayer(player)
	local uid = player.UserId
	local loopId = (activeLoops[uid] and activeLoops[uid].id or 0) + 1
	activeLoops[uid] = { id = loopId }

	local te = player:WaitForChild("TotalEarned", 30)
	if not te then return end

	task.spawn(function()
		while player.Parent and activeLoops[uid] and activeLoops[uid].id == loopId do
			saveToOrderedStore(player, false)
			task.wait(60)
		end
	end)
end

Players.PlayerRemoving:Connect(function(player)
	activeLoops[player.UserId] = nil
	saveToOrderedStore(player, true)
	saveCooldowns[player.UserId] = nil
end)

Players.PlayerAdded:Connect(hookPlayer)
for _, p in pairs(Players:GetPlayers()) do task.spawn(hookPlayer, p) end

