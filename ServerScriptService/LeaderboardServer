	local stroke = Instance.new("UIStroke")
	stroke.Color = isTop3 and TOP3_TEXT[rank] or Color3.fromRGB(45, 45, 65)
	stroke.Thickness = 1.5
	stroke.Transparency = isTop3 and 0.4 or 0.2
