-- ServerScriptService/UpgradesServerHandler.lua

local RepStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")

-- Wait for required folders
local EventsFolder = RepStorage:WaitForChild("Events", 10)
if not EventsFolder then
	warn("Events folder not found in ReplicatedStorage!")
	return
end

-- Load modules
local PlayerSession = require(ServerStorage:WaitForChild("Modules"):WaitForChild("PlayerDataManager"))
local UpgradesData = require(RepStorage:WaitForChild("Modules"):WaitForChild("UpgradesData"))
local ConveyorUpgradeApplier = require(ServerStorage:WaitForChild("Modules"):WaitForChild("ConveyorUpgradeApplier"))
local MinerUpgradeApplier = require(ServerStorage:WaitForChild("Modules"):WaitForChild("MinerUpgradeApplier"))

-- ============================================================
-- Helper to get player upgrades from session
-- ============================================================
local function GetPlayerUpgrades(player)
	local session = PlayerSession.Get(player)
	if not session then
		warn("Player data not loaded in module for", player.Name)
		return {}
	end

	if not session["Upgrades"] then
		session["Upgrades"] = {}
	end

	return session["Upgrades"]
end

-- ============================================================
-- RemoteFunction: get all player upgrades (for UI)
-- ============================================================
local GetPlayerUpgradesRemote = EventsFolder:FindFirstChild("GetPlayerUpgrades")
if GetPlayerUpgradesRemote then
	GetPlayerUpgradesRemote.OnServerInvoke = function(player)
		local upgrades = GetPlayerUpgrades(player)

		-- Ensure all upgrade types exist with default level 0
		for upgradeId, _ in pairs(UpgradesData.Upgrades) do
			if not upgrades[upgradeId] then
				upgrades[upgradeId] = 0
			end
		end

		return upgrades
	end
end

-- ============================================================
-- RemoteFunction: get upgrade definitions (names, costs, icons)
-- ============================================================
local GetUpgradesDataRemote = EventsFolder:FindFirstChild("GetUpgradesData")
if GetUpgradesDataRemote then
	GetUpgradesDataRemote.OnServerInvoke = function(player)
		local clientSafeData = {}
		for upgradeId, upgradeData in pairs(UpgradesData.Upgrades) do
			clientSafeData[upgradeId] = {
				Name = upgradeData.Name,
				Description = upgradeData.Description,
				Icon = upgradeData.Icon,
				BaseCost = upgradeData.BaseCost,
				CostMultiplier = upgradeData.CostMultiplier,
				MaxLevel = upgradeData.MaxLevel,
				SortOrder = upgradeData.SortOrder,
			}
		end
		return clientSafeData
	end
end

-- ============================================================
-- RemoteFunction: buy one level of an upgrade
-- ============================================================
local BuyUpgradeRemote = EventsFolder:FindFirstChild("BuyUpgrade")
if BuyUpgradeRemote then
	BuyUpgradeRemote.OnServerInvoke = function(player, upgradeId)
		local upgradeData = UpgradesData.Upgrades[upgradeId]
		if not upgradeData then return false end

		local session = PlayerSession.Get(player)
		if not session then return false end

		local upgrades = GetPlayerUpgrades(player)
		local currentLevel = upgrades[upgradeId] or 0

		if UpgradesData.IsMaxLevel(upgradeId, currentLevel) then return false end

		local cost = UpgradesData.GetUpgradeCost(upgradeId, currentLevel)
		local cashValue = ServerStorage.ServerLockedPlayerInfo.PlayerCash:FindFirstChild(player.Name)

		if not cashValue or cashValue.Value < cost then return false end

		-- Process purchase
		cashValue.Value -= cost
		local newLevel = currentLevel + 1
		upgrades[upgradeId] = newLevel

		--print(player.Name .. " upgraded " .. upgradeData.Name .. " to level " .. newLevel)

		-- Trigger appliers
		if upgradeId == "ConveyorSpeed" then
			ConveyorUpgradeApplier.ApplyToPlayerPlot(player, newLevel)
		elseif upgradeId == "IronMineSpeed" then
			MinerUpgradeApplier.ApplyToPlayerPlot(player, "Iron Mine")
		elseif upgradeId == "CopperMineSpeed" then
			MinerUpgradeApplier.ApplyToPlayerPlot(player, "Copper Mine")
		elseif upgradeId == "GoldMineSpeed" then
			MinerUpgradeApplier.ApplyToPlayerPlot(player, "Gold Mine")
		elseif upgradeId == "MovementSpeed" then
			if _G.ApplyWalkspeedUpgrade then
				_G.ApplyWalkspeedUpgrade(player)
			else
				local char = player.Character
				if char and char:FindFirstChild("Humanoid") then
					char.Humanoid.WalkSpeed = 16 + newLevel
				end
			end
		end
		-- CashBonus, GemDiscovery, DoubleDropChance are passive — no applier needed

		return true
	end
end

-- ============================================================
-- Global: get upgrade multiplier (used by other server scripts)
-- ============================================================
local function GetUpgradeMultiplier(player, upgradeId)
	local upgrades = GetPlayerUpgrades(player)
	local level = upgrades[upgradeId] or 0
	return UpgradesData.GetUpgradeMultiplier(upgradeId, level)
end

_G.GetUpgradeMultiplier = GetUpgradeMultiplier

-- ============================================================
-- DEV PRODUCT HELPER: max a single upgrade instantly
-- Called by GamepassHandler's ProcessReceipt
-- ============================================================
local function ApplyUpgradeEffects(player, upgradeId, newLevel)
	if upgradeId == "ConveyorSpeed" then
		ConveyorUpgradeApplier.ApplyToPlayerPlot(player, newLevel)
	elseif upgradeId == "IronMineSpeed" then
		MinerUpgradeApplier.ApplyToPlayerPlot(player, "Iron Mine")
	elseif upgradeId == "CopperMineSpeed" then
		MinerUpgradeApplier.ApplyToPlayerPlot(player, "Copper Mine")
	elseif upgradeId == "GoldMineSpeed" then
		MinerUpgradeApplier.ApplyToPlayerPlot(player, "Gold Mine")
	elseif upgradeId == "MovementSpeed" then
		if _G.ApplyWalkspeedUpgrade then
			_G.ApplyWalkspeedUpgrade(player)
		else
			local char = player.Character
			if char and char:FindFirstChild("Humanoid") then
				char.Humanoid.WalkSpeed = 16 + newLevel
			end
		end
	end
	-- CashBonus, GemDiscovery, DoubleDropChance are passive — no applier needed
end

_G.MaxUpgradeForPlayer = function(player, upgradeId)
	local upgradeData = UpgradesData.Upgrades[upgradeId]
	if not upgradeData then
		warn("MaxUpgradeForPlayer: unknown upgradeId:", upgradeId)
		return false
	end

	local upgrades = GetPlayerUpgrades(player)
	local maxLevel = upgradeData.MaxLevel

	-- Already maxed — idempotent, still return true so receipt is granted
	if (upgrades[upgradeId] or 0) >= maxLevel then
		return true
	end

	upgrades[upgradeId] = maxLevel
	ApplyUpgradeEffects(player, upgradeId, maxLevel)

	--print(player.Name .. " maxed upgrade [" .. upgradeId .. "] via dev product (level " .. maxLevel .. ")")
	return true
end

--print("Upgrades server handler loaded successfully!")
