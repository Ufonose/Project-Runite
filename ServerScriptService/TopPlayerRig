-- ServerScriptService/TopPlayerRig
local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")
local ServerStorage = game:GetService("ServerStorage")

local CHECK_INTERVAL = 30
local EarnedStore = DataStoreService:GetOrderedDataStore("TotalEarned_v13")
local spawnPoint  = workspace:WaitForChild("Leaderboards"):WaitForChild("RigSpawnPoint")
local rigTemplate = ServerStorage:WaitForChild("TopPlayerRig")
local danceAnim   = rigTemplate:WaitForChild("DanceAnimation")

local currentRig       = nil
local currentTopUserId = nil

-- ── SUFFIX ────────────────────────────────────────────────────────────────
local function suffixNum(n)
	if n >= 1e12 then return string.format("$%.1fT", n / 1e12)
	elseif n >= 1e9  then return string.format("$%.1fB", n / 1e9)
	elseif n >= 1e6  then return string.format("$%.1fM", n / 1e6)
	elseif n >= 1e3  then return string.format("$%.1fK", n / 1e3)
	else return "$" .. math.floor(n) end
end

-- ── NAMETAG ───────────────────────────────────────────────────────────────
local function createNametag(rig, name, cash)
	local head = rig:FindFirstChild("Head")
	if not head then return end

	local existing = head:FindFirstChild("TrophyGui")
	if existing then existing:Destroy() end

	local humanoid = rig:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid.DisplayName = name
	end

	local gui = Instance.new("BillboardGui")
	gui.Name = "TrophyGui"
	gui.Size = UDim2.new(4, 0, 2.5, 0)
	gui.StudsOffset = Vector3.new(0, 4, 0)
	gui.AlwaysOnTop = false
	gui.LightInfluence = 0
	gui.Parent = head

	local trophy = Instance.new("ImageLabel")
	trophy.Size = UDim2.new(0.25, 0, 0.6, 0)
	trophy.AnchorPoint = Vector2.new(0, 0.5)
	trophy.Position = UDim2.new(0, 0, 0.5, 0)
	trophy.BackgroundTransparency = 1
	trophy.Image = "rbxassetid://9722127533"
	trophy.ScaleType = Enum.ScaleType.Fit
	trophy.Parent = gui

	local cashLabel = Instance.new("TextLabel")
	cashLabel.Size = UDim2.new(0.7, 0, 0.6, 0)
	cashLabel.AnchorPoint = Vector2.new(0, 0.5)
	cashLabel.Position = UDim2.new(0.28, 0, 0.5, 0)
	cashLabel.BackgroundTransparency = 1
	cashLabel.Text = suffixNum(cash)
	cashLabel.TextColor3 = Color3.fromRGB(80, 220, 120)
	cashLabel.TextScaled = true
	cashLabel.Font = Enum.Font.GothamBold
	cashLabel.TextXAlignment = Enum.TextXAlignment.Left
	cashLabel.Parent = gui

	local tc = Instance.new("UITextSizeConstraint", cashLabel)
	tc.MaxTextSize = 18
end

-- ── SPAWN RIG ─────────────────────────────────────────────────────────────
local function spawnRig(userId, cash)
	if currentRig then
		currentRig:Destroy()
		currentRig = nil
	end

	local rig = rigTemplate:Clone()
	rig.Name = "TopPlayerRig_Active"
	rig.Parent = workspace

	local hrp = rig:FindFirstChild("HumanoidRootPart")
	if hrp then
		hrp.CFrame = spawnPoint.CFrame + Vector3.new(0, spawnPoint.Size.Y / 2 + 3, 0)
		hrp.Anchored = true
	end

	for _, part in pairs(rig:GetDescendants()) do
		if part:IsA("BasePart") then
			part.CanCollide = false
		end
	end

	task.spawn(function()
		local humanoid = rig:FindFirstChildOfClass("Humanoid")
		if not humanoid then return end

		local ok, desc = pcall(function()
			return Players:GetHumanoidDescriptionFromUserIdAsync(userId)
		end)
		if ok and desc then
			pcall(function()
				humanoid:ApplyDescriptionResetAsync(desc)
			end)
		end

		local nameOk, name = pcall(function()
			return Players:GetNameFromUserIdAsync(userId)
		end)
		createNametag(rig, nameOk and name or "Unknown", cash)
	end)

	task.spawn(function()
		local humanoid = rig:FindFirstChildOfClass("Humanoid")
		if not humanoid then return end
		local animator = humanoid:WaitForChild("Animator", 5)
		if not animator then return end

		local anim = Instance.new("Animation")
		anim.AnimationId = danceAnim.AnimationId
		local track = animator:LoadAnimation(anim)
		track.Looped = true
		track:Play()
	end)

	currentRig = rig
	currentTopUserId = userId
end

-- ── FETCH TOP PLAYER ──────────────────────────────────────────────────────
local function fetchTopPlayer()
	local topUserId, topCash = nil, 0

	local ok, pages = pcall(function()
		return EarnedStore:GetSortedAsync(false, 1)
	end)
	if ok and pages then
		local data = pages:GetCurrentPage()
		if #data > 0 then
			topUserId = tonumber(data[1].key)
			topCash   = data[1].value
		end
	end

	-- Override with any online player who has a higher live value
	for _, player in pairs(Players:GetPlayers()) do
		local te = player:FindFirstChild("TotalEarned")
		if te and te.Value > topCash then
			topUserId = player.UserId
			topCash   = te.Value
		end
	end

	return topUserId, topCash
end

-- ── MAIN LOOP ─────────────────────────────────────────────────────────────
while true do
	local topUserId, cash = fetchTopPlayer()

	if topUserId and topUserId ~= currentTopUserId then
		spawnRig(topUserId, cash)
	end

	task.wait(CHECK_INTERVAL)
end
