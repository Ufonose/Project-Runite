-- ServerScriptService/SpeedrunLeaderboardServer
local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")

local leaderboardPart = workspace:WaitForChild("Leaderboards"):WaitForChild("SpeedrunLeaderboard") -- adjust path

local DS_FETCH_INTERVAL   = 120
local LIVE_UPDATE_INTERVAL = 5
local MAX_ENTRIES = 100
local ROW_HEIGHT  = 36
local ROW_PADDING = 5

local SpeedrunStore = DataStoreService:GetOrderedDataStore("Speedrun_Total_v1")
local cachedData    = {}

-- ── TIME FORMAT ───────────────────────────────────────────────────────────
local function formatTime(s)
	s = math.floor(math.abs(s))
	local h   = math.floor(s / 3600)
	local m   = math.floor((s % 3600) / 60)
	local sec = s % 60
	return h > 0
		and string.format("%d:%02d:%02d", h, m, sec)
		or  string.format("%d:%02d", m, sec)
end

