-- ── FETCH DS ──────────────────────────────────────────────────────────────
local function fetchFromDataStore()
	local results = {}
	local ok, pages = pcall(function()
		return SpeedrunStore:GetSortedAsync(false, MAX_ENTRIES)
	end)
	if not ok then warn("Speedrun DS fetch failed:", pages) return results end

	while true do
		for _, entry in pairs(pages:GetCurrentPage()) do
			local uid = tonumber(entry.key)
			if not nameCache[uid] then
				local nameOk, res = pcall(function()
					return Players:GetNameFromUserIdAsync(uid)
				end)
				nameCache[uid] = nameOk and res or "[Unknown]"
			end
			results[uid] = { name = nameCache[uid], seconds = math.abs(entry.value), userId = uid }
		end
		if pages.IsFinished then break end
		pages:AdvanceToNextPageAsync()
	end

	return results
end

-- ── MERGE DATA ────────────────────────────────────────────────────────────
local function getMergedData()
	local merged = {}

	for uid, entry in pairs(cachedData) do
		merged[uid] = { name = entry.name, seconds = entry.seconds, online = false, userId = uid }
	end

	for _, player in pairs(Players:GetPlayers()) do
		local pb = player:FindFirstChild("SpeedrunPB")
		if pb and pb.Value > 0 then
			nameCache[player.UserId] = player.Name
			local existing = merged[player.UserId]
			if not existing or pb.Value < existing.seconds then
				merged[player.UserId] = {
					name    = player.Name,
					seconds = pb.Value,
					online  = true,
					userId  = player.UserId,
				}
			else
				merged[player.UserId].online = true
			end
		elseif merged[player.UserId] then
			-- FIX: player is online and in the DS leaderboard but SpeedrunPB not set yet;
			-- still show the green dot
			merged[player.UserId].online = true
		end
	end

	local arr = {}
	for _, v in pairs(merged) do table.insert(arr, v) end
	table.sort(arr, function(a, b) return a.seconds < b.seconds end)
	return arr
end

-- ── POPULATE GUI ──────────────────────────────────────────────────────────
local function populateGui(gui, data)
	local scroll = gui.Background:FindFirstChild("EntryList")
	if not scroll then return end

	for _, c in pairs(scroll:GetChildren()) do
		if c:IsA("Frame") then c:Destroy() end
	end

	if #data == 0 then
		createRow(scroll, 1, "No runs completed yet!", 0, false, nil)
		scroll.CanvasSize = UDim2.new(0, 0, 0, ROW_HEIGHT)
		return
	end

	for i, entry in ipairs(data) do
		createRow(scroll, i, entry.name, entry.seconds, entry.online, entry.userId)
	end

	scroll.CanvasSize = UDim2.new(0, 0, 0, #data * (ROW_HEIGHT + ROW_PADDING))
end

-- ── RIG NAMETAG ───────────────────────────────────────────────────────────
local function createNametag(rig, name, timeSeconds)
	local head = rig:FindFirstChild("Head")
	if not head then return end

	local existing = head:FindFirstChild("TrophyGui")
	if existing then existing:Destroy() end

	local humanoid = rig:FindFirstChildOfClass("Humanoid")
	if humanoid then humanoid.DisplayName = name end

	local gui = Instance.new("BillboardGui")
	gui.Name = "TrophyGui"
	gui.Size = UDim2.new(4, 0, 2.5, 0)
	gui.StudsOffset = Vector3.new(0, 4, 0)
	gui.AlwaysOnTop = false
	gui.LightInfluence = 0
	gui.Parent = head

	local trophy = Instance.new("ImageLabel")
	trophy.Size = UDim2.new(0.25, 0, 0.6, 0)
	trophy.AnchorPoint = Vector2.new(0, 0.5)
	trophy.Position = UDim2.new(0, 0, 0.5, 0)
	trophy.BackgroundTransparency = 1
	trophy.Image = "rbxassetid://9722127533"
	trophy.ScaleType = Enum.ScaleType.Fit
	trophy.Parent = gui

	local timeLabel = Instance.new("TextLabel")
	timeLabel.Name = "TimeLabel"
	timeLabel.Size = UDim2.new(0.7, 0, 0.6, 0)
	timeLabel.AnchorPoint = Vector2.new(0, 0.5)
	timeLabel.Position = UDim2.new(0.28, 0, 0.5, 0)
	timeLabel.BackgroundTransparency = 1
	timeLabel.Text = formatTime(timeSeconds)
	timeLabel.TextColor3 = Color3.fromRGB(80, 220, 120)
	timeLabel.TextScaled = true
	timeLabel.Font = Enum.Font.GothamBold
	timeLabel.TextXAlignment = Enum.TextXAlignment.Left
	timeLabel.Parent = gui

	local tc = Instance.new("UITextSizeConstraint", timeLabel)
	tc.MaxTextSize = 18
end

-- ── SPAWN RIG ─────────────────────────────────────────────────────────────
local function spawnRig(userId, timeSeconds)
	if currentRig then
		currentRig:Destroy()
		currentRig = nil
	end

	local rig = rigTemplate:Clone()
	rig.Name = "SpeedrunTopPlayerRig_Active"
	rig.Parent = workspace

	local hrp = rig:FindFirstChild("HumanoidRootPart")
	if hrp then
		hrp.CFrame = spawnPoint.CFrame + Vector3.new(0, spawnPoint.Size.Y / 2 + 3, 0)
		hrp.Anchored = true
	end

	for _, part in pairs(rig:GetDescendants()) do
		if part:IsA("BasePart") then part.CanCollide = false end
	end

	task.spawn(function()
		local humanoid = rig:FindFirstChildOfClass("Humanoid")
		if not humanoid then return end

		local ok, desc = pcall(function()
			return Players:GetHumanoidDescriptionFromUserIdAsync(userId)
		end)
		if ok and desc then
			pcall(function() humanoid:ApplyDescriptionResetAsync(desc) end)
		end

		local name = nameCache[userId] or "Unknown"
		createNametag(rig, name, timeSeconds)
	end)

	task.spawn(function()
		local humanoid = rig:FindFirstChildOfClass("Humanoid")
		if not humanoid then return end
		local animator = humanoid:WaitForChild("Animator", 5)
		if not animator then return end

		local anim = Instance.new("Animation")
		anim.AnimationId = danceAnim.AnimationId
		local track = animator:LoadAnimation(anim)
		track.Looped = true
		track:Play()
	end)

	currentRig = rig
	currentTopUserId = userId
	currentTopSeconds = timeSeconds
end

-- ── UPDATE RIG NAMETAG IN PLACE ───────────────────────────────────────────
local function updateRigTime(timeSeconds)
	if not currentRig then return end
	local head = currentRig:FindFirstChild("Head")
	if not head then return end
	local trophyGui = head:FindFirstChild("TrophyGui")
	if not trophyGui then return end
	local label = trophyGui:FindFirstChild("TimeLabel")
	if label then label.Text = formatTime(timeSeconds) end
end

-- ── UPDATE RIG ────────────────────────────────────────────────────────────
local function updateRig(data)
	if #data == 0 then return end
	local top = data[1]
	if top.seconds <= 0 then return end

	if top.userId ~= currentTopUserId then
		spawnRig(top.userId, top.seconds)
	elseif top.seconds ~= currentTopSeconds then
		updateRigTime(top.seconds)
		currentTopSeconds = top.seconds
	end
end

-- ── MAIN ──────────────────────────────────────────────────────────────────
local gui = buildGui(leaderboardPart)

-- FIX: DS fetch runs in its own loop so heavy yielding never blocks live updates
task.spawn(function()
	while true do
		cachedData = fetchFromDataStore()
		task.wait(DS_FETCH_INTERVAL)
	end
end)

-- Live update loop runs every 5s uninterrupted
while true do
	local merged = getMergedData()
	pcall(populateGui, gui, merged)
	pcall(updateRig, merged)
	task.wait(LIVE_UPDATE_INTERVAL)
end
