-- ServerScriptService/ConveyorManagerUnstuck
local RunService = game:GetService("RunService")

local conveyorParts = {}

local Players = game:GetService("Players")

-- OverlapParams filtered to Ores collision group only
local overlapParams = OverlapParams.new()
overlapParams.FilterType = Enum.RaycastFilterType.Include
overlapParams.CollisionGroup = "Ores"

-- Cache plot owner per SideStuck part to avoid walking up hierarchy every frame
local partOwnerCache = {}

-- Find the root item model that holds the ConveyorReversed attribute
local function getPlotOwner(part)
	local ancestor = part.Parent
	while ancestor and ancestor ~= workspace do
		if ancestor.Parent == workspace.Plots then
			local ownerVal = ancestor:FindFirstChild("Owner")
			if ownerVal then
				return Players:FindFirstChild(ownerVal.Value)
			end
			return nil
		end
		ancestor = ancestor.Parent
	end
	return nil
end

local function getRootItem(part)
	local ancestor = part.Parent
	while ancestor and ancestor ~= workspace do
		if ancestor:IsA("Model") and ancestor:GetAttribute("ConveyorReversed") ~= nil then
			return ancestor
		end
		ancestor = ancestor.Parent
	end
	return nil
end

local function getSpeed(data)
	local baseSpeed = data.baseSpeed
	-- NoFlip parts always use their fixed baseSpeed regardless of ConveyorReversed
	if data.noFlip then
		return baseSpeed
	end
	if data.rootItem and data.rootItem:GetAttribute("ConveyorReversed") == true then
		return -baseSpeed
	end
	return baseSpeed
end

local function registerConveyor(conveyorPart)
	local isNoFlip = conveyorPart.Name == "ConvMerge" or conveyorPart.Name == "SideStuckMerge"
	if isNoFlip then
		conveyorPart:SetAttribute("NoFlip", true)
	end

	local speedValue = conveyorPart:FindFirstChild("ConvVelo")
	local baseSpeed = 7
	if speedValue and speedValue:IsA("ValueBase") then
		baseSpeed = math.abs(speedValue.Value)
	elseif conveyorPart:GetAttribute("Speed") then
		baseSpeed = math.abs(conveyorPart:GetAttribute("Speed"))
	end

	table.insert(conveyorParts, {
		part      = conveyorPart,
		baseSpeed = baseSpeed,
		rootItem  = getRootItem(conveyorPart),
		noFlip    = isNoFlip,
		owner     = getPlotOwner(conveyorPart), -- cached at register time
	})
end

local function unregisterConveyor(conveyorPart)
	for i, data in ipairs(conveyorParts) do
		if data.part == conveyorPart then
			table.remove(conveyorParts, i)
			break
		end
	end
end

for _, plot in pairs(workspace.Plots:GetChildren()) do
	for _, descendant in pairs(plot:GetDescendants()) do
		if descendant:IsA("BasePart") and (descendant.Name == "SideStuck" or descendant.Name == "SideStuckMerge") then
			registerConveyor(descendant)
		end
	end
end

workspace.DescendantAdded:Connect(function(descendant)
	if descendant:IsA("BasePart") and (descendant.Name == "SideStuck" or descendant.Name == "SideStuckMerge") then
		task.wait(0.1)
		registerConveyor(descendant)
	end
end)

workspace.DescendantRemoving:Connect(function(descendant)
	if descendant:IsA("BasePart") and (descendant.Name == "SideStuck" or descendant.Name == "SideStuckMerge") then
		unregisterConveyor(descendant)
	end
end)

local updateCounter = 0
RunService.Heartbeat:Connect(function()
	updateCounter = updateCounter + 1
	if updateCounter >= 2 then
		updateCounter = 0

		for _, data in ipairs(conveyorParts) do
			local part = data.part
			if part and part.Parent then
				local speed = getSpeed(data)
				part.AssemblyLinearVelocity = part.CFrame.LookVector * speed

				-- Slightly shrink search volume to avoid false positives from adjacent belts
				local searchSize = part.Size - Vector3.new(0.2, 0, 0.2)
				local hits = workspace:GetPartBoundsInBox(part.CFrame, searchSize, overlapParams)
				for _, hit in ipairs(hits) do
					if hit:CanSetNetworkOwnership() then
						hit:SetNetworkOwner(data.owner) -- plot owner, nil if they left
					end
				end
			end
		end
	end
end)

print("Conveyor Manager Unstuck (Classic Mode) loaded! Managing", #conveyorParts, "parts.")
