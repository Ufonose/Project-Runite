local rigTemplate     = ServerStorage:WaitForChild("TopPlayerRig")
local danceAnim       = rigTemplate:WaitForChild("DanceAnimation")

local DS_FETCH_INTERVAL    = 120
local LIVE_UPDATE_INTERVAL = 10
local TIME_SAVE_INTERVAL   = 120 -- increased from 60 to match DS fetch interval
local MAX_ENTRIES          = 100
local ROW_HEIGHT            = 36
local ROW_PADDING           = 5

local TimeStore  = DataStoreService:GetOrderedDataStore("TimePlayed_v1lol")
local cachedData = {}
local nameCache  = {}
local saveCooldowns = {}

local currentRig        = nil
local currentTopUserId  = nil
local currentTopSeconds = 0

-- ── TIME TRACKING ─────────────────────────────────────────────────────────
local sessionStart = {}

local function getSessionSeconds(player)
	local start = sessionStart[player.UserId]
	if not start then return 0 end
	return math.floor(tick() - start)
end

local function getTotalSeconds(player)
	local stored = player:FindFirstChild("TimePlayed")
	return (stored and stored.Value or 0) + getSessionSeconds(player)
end

local function saveTimeToStore(player)
	local now = os.time()
	if saveCooldowns[player.UserId] and now - saveCooldowns[player.UserId] < TIME_SAVE_INTERVAL then return end
	saveCooldowns[player.UserId] = now

	local total = getTotalSeconds(player)
	if total <= 0 then return end
	pcall(function()
		TimeStore:SetAsync(tostring(player.UserId), total)
	end)
end

-- ── PLAYER HOOKS ──────────────────────────────────────────────────────────
local activeLoops = {}

local function hookPlayer(player)
	local uid = player.UserId
	local loopId = (activeLoops[uid] and activeLoops[uid].id or 0) + 1
	activeLoops[uid] = { id = loopId }

	player:WaitForChild("DataLoaded", 30)

	local stored = Instance.new("NumberValue")
	stored.Name = "TimePlayed"
	stored.Value = 0
	stored.Parent = player

	local ok, saved = pcall(function()
		return TimeStore:GetAsync(tostring(player.UserId))
	end)
	if ok and saved then stored.Value = saved end

	sessionStart[uid] = tick()
	nameCache[uid] = player.Name

	task.spawn(function()
		while player.Parent and activeLoops[uid] and activeLoops[uid].id == loopId do
			task.wait(TIME_SAVE_INTERVAL)
			if not player.Parent then break end
			stored.Value = stored.Value + getSessionSeconds(player)
			sessionStart[uid] = tick()
			saveTimeToStore(player)
		end
	end)
end

Players.PlayerAdded:Connect(function(player) task.spawn(hookPlayer, player) end)

Players.PlayerRemoving:Connect(function(player)
	activeLoops[player.UserId] = nil
	local stored = player:FindFirstChild("TimePlayed")
	if stored then
		stored.Value = stored.Value + getSessionSeconds(player)
	end
	local total = getTotalSeconds(player)
	if total > 0 then
		pcall(function()
			TimeStore:SetAsync(tostring(player.UserId), total)
		end)
	end
	sessionStart[player.UserId] = nil
	saveCooldowns[player.UserId] = nil
end)

for _, p in pairs(Players:GetPlayers()) do task.spawn(hookPlayer, p) end

-- ── FORMAT TIME ───────────────────────────────────────────────────────────
local function formatTime(seconds)
	local d = math.floor(seconds / 86400)
	local h = math.floor((seconds % 86400) / 3600)
	local m = math.floor((seconds % 3600) / 60)
	if d > 0 then return string.format("%dd %dh %dm", d, h, m)
	elseif h > 0 then return string.format("%dh %dm", h, m)
	else return string.format("%dm", m) end
end

