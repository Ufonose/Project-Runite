-- ── SAVE HOOK ─────────────────────────────────────────────────────────────
local saveCooldowns = {}

local function saveRuns(player, force)
	local session = PlayerSession.Get(player)
	if not session then return end
	local runs = session.Speedrun and session.Speedrun.TotalRuns or 0
	if runs <= 0 then return end

	local now = os.time()
	if not force then
		if saveCooldowns[player.UserId] and now - saveCooldowns[player.UserId] < 60 then return end
	end
	saveCooldowns[player.UserId] = now

	pcall(function()
		RunsStore:SetAsync(tostring(player.UserId), runs)
	end)
end

local activeLoops = {}

local function hookPlayer(player)
	local uid = player.UserId
	local loopId = (activeLoops[uid] and activeLoops[uid].id or 0) + 1
	activeLoops[uid] = { id = loopId }

	player:WaitForChild("DataLoaded", 30)

	task.spawn(function()
		while player.Parent and activeLoops[uid] and activeLoops[uid].id == loopId do
			saveRuns(player, false)
			task.wait(60)
		end
	end)
end

Players.PlayerAdded:Connect(hookPlayer)
Players.PlayerRemoving:Connect(function(player)
	activeLoops[player.UserId] = nil
	saveRuns(player, true)
	saveCooldowns[player.UserId] = nil
end)
for _, p in pairs(Players:GetPlayers()) do task.spawn(hookPlayer, p) end

