-- ── SPAWN RIG ─────────────────────────────────────────────────────────────
local function spawnRig(userId, runs)
	if currentRig then
		currentRig:Destroy()
		currentRig = nil
	end

	local rig = rigTemplate:Clone()
	rig.Name = "RunsTopPlayerRig_Active"
	rig.Parent = workspace

	local hrp = rig:FindFirstChild("HumanoidRootPart")
	if hrp then
		hrp.CFrame = spawnPoint.CFrame + Vector3.new(0, spawnPoint.Size.Y / 2 + 3, 0)
		hrp.Anchored = true
	end

	for _, part in pairs(rig:GetDescendants()) do
		if part:IsA("BasePart") then part.CanCollide = false end
	end

	task.spawn(function()
		local humanoid = rig:FindFirstChildOfClass("Humanoid")
		if not humanoid then return end

		local ok, desc = pcall(function()
			return Players:GetHumanoidDescriptionFromUserIdAsync(userId)
		end)
		if ok and desc then
			pcall(function() humanoid:ApplyDescriptionResetAsync(desc) end)
		end

		local name = nameCache[userId] or "Unknown"
		createNametag(rig, name, runs)
	end)

	task.spawn(function()
		local humanoid = rig:FindFirstChildOfClass("Humanoid")
		if not humanoid then return end
		local animator = humanoid:WaitForChild("Animator", 5)
		if not animator then return end

		local anim = Instance.new("Animation")
		anim.AnimationId = danceAnim.AnimationId
		local track = animator:LoadAnimation(anim)
		track.Looped = true
		track:Play()
	end)

	currentRig = rig
	currentTopUserId = userId
end

-- ── UPDATE RIG NAMETAG IN PLACE ───────────────────────────────────────────
local function updateRigRuns(runs)
	if not currentRig then return end
	local head = currentRig:FindFirstChild("Head")
	if not head then return end
	local trophyGui = head:FindFirstChild("TrophyGui")
	if not trophyGui then return end
	for _, child in ipairs(trophyGui:GetDescendants()) do
		if child:IsA("TextLabel") then
			child.Text = runs .. " runs"
			break
		end
	end
end

-- ── UPDATE RIG ────────────────────────────────────────────────────────────
local function updateRig(data)
	if #data == 0 then return end
	local top = data[1]
	if top.runs <= 0 then return end

	if top.userId ~= currentTopUserId then
		spawnRig(top.userId, top.runs)
		currentTopRuns = top.runs
	elseif top.runs ~= currentTopRuns then
		updateRigRuns(top.runs)
		currentTopRuns = top.runs
	end
end

-- ── MAIN ──────────────────────────────────────────────────────────────────
local gui = buildGui(leaderboardPart)
local lastDsFetch = 0

while true do
	local now = os.time()
	if now - lastDsFetch >= DS_FETCH_INTERVAL then
		cachedData = fetchFromDataStore()
		lastDsFetch = now
	end

	local merged = getMergedData()
	pcall(populateGui, gui, merged)
	pcall(updateRig, merged)

	task.wait(LIVE_UPDATE_INTERVAL)
end
