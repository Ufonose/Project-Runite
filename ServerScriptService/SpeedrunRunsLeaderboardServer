end

-- ── FETCH DS ──────────────────────────────────────────────────────────────
local function fetchFromDataStore()
	local results = {}
	local ok, pages = pcall(function()
		return RunsStore:GetSortedAsync(false, MAX_ENTRIES)
	end)
	if not ok then warn("Runs DS fetch failed:", pages) return results end

	while true do
		for _, entry in pairs(pages:GetCurrentPage()) do
			local uid = tonumber(entry.key)
			local name = "[Unknown]"
			local nameOk, res = pcall(function()
				return Players:GetNameFromUserIdAsync(uid)
			end)
			if nameOk then name = res end
			results[uid] = { name = name, runs = entry.value, userId = uid }
		end
		if pages.IsFinished then break end
		pages:AdvanceToNextPageAsync()
	end

	return results
end

-- ── MERGE DATA (live online players blended in) ───────────────────────────
local function getMergedData()
	local merged = {}

	for uid, entry in pairs(cachedData) do
		merged[uid] = { name = entry.name, runs = entry.runs, online = false, userId = uid }
	end

	for _, player in pairs(Players:GetPlayers()) do
		local session = PlayerSession.Get(player)
		local runs = session and session.Speedrun and session.Speedrun.TotalRuns or 0
		if runs > 0 then
			merged[player.UserId] = { name = player.Name, runs = runs, online = true, userId = player.UserId }
		end
	end

	local arr = {}
	for _, v in pairs(merged) do table.insert(arr, v) end
	table.sort(arr, function(a, b) return a.runs > b.runs end)
	return arr
end

-- ── POPULATE ──────────────────────────────────────────────────────────────
local function populateGui(gui, data)
	local scroll = gui.Background:FindFirstChild("EntryList")
	if not scroll then return end

	for _, c in pairs(scroll:GetChildren()) do
		if c:IsA("Frame") then c:Destroy() end
	end

	if #data == 0 then
		createRow(scroll, 1, "No runs completed yet!", 0, false, nil)
		scroll.CanvasSize = UDim2.new(0, 0, 0, ROW_HEIGHT)
		return
	end

	for i, entry in ipairs(data) do
		createRow(scroll, i, entry.name, entry.runs, entry.online, entry.userId)
	end

	scroll.CanvasSize = UDim2.new(0, 0, 0, #data * (ROW_HEIGHT + ROW_PADDING))
end

-- ── MAIN ──────────────────────────────────────────────────────────────────
local gui = buildGui(leaderboardPart)
local lastDsFetch = 0

while true do
	local now = os.time()
	if now - lastDsFetch >= DS_FETCH_INTERVAL then
		cachedData = fetchFromDataStore()
		lastDsFetch = now
	end
	pcall(populateGui, gui, getMergedData())
	task.wait(LIVE_UPDATE_INTERVAL)
end
