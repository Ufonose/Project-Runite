-- ServerScriptService/SpeedrunRunsLeaderboardServer
local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")
local ServerStorage = game:GetService("ServerStorage")

local leaderboardPart = workspace:WaitForChild("Leaderboards"):WaitForChild("RunsLeaderboard") -- adjust path

local DS_FETCH_INTERVAL    = 120
local LIVE_UPDATE_INTERVAL = 5
local MAX_ENTRIES = 100
local ROW_HEIGHT  = 36
local ROW_PADDING = 5

local RunsStore  = DataStoreService:GetOrderedDataStore("Speedrun_TotalRuns_v1")
local cachedData = {}

-- ── SAVE HOOK ─────────────────────────────────────────────────────────────
local saveCooldowns = {}
local PlayerSession = require(ServerStorage.Modules.PlayerDataManager)

local function saveRuns(player, force)
	local session = PlayerSession.Get(player)
	if not session then return end
	local runs = session.Speedrun and session.Speedrun.TotalRuns or 0
	if runs <= 0 then return end

	local now = os.time()
	if not force then
		if saveCooldowns[player.UserId] and now - saveCooldowns[player.UserId] < 60 then return end
	end
	saveCooldowns[player.UserId] = now

	pcall(function()
		RunsStore:SetAsync(tostring(player.UserId), runs)
	end)
end

local function hookPlayer(player)
	player:WaitForChild("DataLoaded", 30)
	task.spawn(function()
		while player.Parent do
			saveRuns(player, false)
			task.wait(60)
		end
	end)
end

Players.PlayerAdded:Connect(hookPlayer)
Players.PlayerRemoving:Connect(function(player)
	saveRuns(player, true)
	saveCooldowns[player.UserId] = nil
end)
for _, p in pairs(Players:GetPlayers()) do task.spawn(hookPlayer, p) end

