-- ServerScriptService/WithdrawItemsHandler

local RepStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")
local Plrs = game:GetService("Players")

-- MODULES
local PlayerSession = require(ServerStorage.Modules.PlayerDataManager)

-- Create the RemoteFunction if it doesn't exist
local withdrawItemsRemote = RepStorage.Events:FindFirstChild("WithdrawAllItems")
if not withdrawItemsRemote then
	withdrawItemsRemote = Instance.new("RemoteFunction")
	withdrawItemsRemote.Name = "WithdrawAllItems"
	withdrawItemsRemote.Parent = RepStorage.Events
end

-- Function to check if an item should be excluded from withdrawal
local function shouldExclude(item)
	-- Check if item is a hotspot miner or furnace (permanent plot items)
	if item:GetAttribute("HotspotMiner") == true then
		return true
	end

	if item:GetAttribute("HotspotFurnace") == true then
		return true
	end

	-- Backup check for Standard Furnace by ID
	local itemStatsScript = item:FindFirstChild("ItemStats")
	if itemStatsScript and itemStatsScript:IsA("ModuleScript") then
		-- Use '::' to tell Luau this is definitely a ModuleScript
		local success, itemInfo = pcall(function() return require(itemStatsScript :: ModuleScript) end)
		if success and itemInfo and itemInfo.ItemId == 3 then
			return true
		end
	end

	return false
end

-- Function to withdraw all items from a player's plot
local function withdrawAllItems(player)
	local session = PlayerSession.Get(player)
	if not session then
		warn("Data session not found for", player.Name)
		return false
	end

	local playerPlot = player:FindFirstChild("SetPlot") and player.SetPlot.Value
	if not playerPlot then return false end

	local placedItems = playerPlot:FindFirstChild("PlacedItems")
	if not placedItems then return false end

	local itemsWithdrawn = 0

	-- Loop through all items in PlacedItems
	for _, item in pairs(placedItems:GetChildren()) do
		if not shouldExclude(item) then
			local itemStatsScript = item:FindFirstChild("ItemStats")

			if itemStatsScript and itemStatsScript:IsA("ModuleScript") then
				-- Type assertion here as well
				local success, itemInfo = pcall(function() return require(itemStatsScript :: ModuleScript) end)

				if success and itemInfo then
					local itemIdStr = tostring(itemInfo.ItemId)

					-- Update ProfileStore session
					if session["Items"][itemIdStr] then
						session["Items"][itemIdStr]["Amount"] += 1
						itemsWithdrawn += 1
					end

					-- Destroy the item from the plot
					item:Destroy()
				end
			end
		end
	end

	-- Update the player's inventory UI
	if itemsWithdrawn > 0 then
		RepStorage.Events.InventoryUpdate:FireClient(player)
		print("Successfully withdrew", itemsWithdrawn, "items for", player.Name)
	end

	return true
end

-- Set up the remote function
withdrawItemsRemote.OnServerInvoke = withdrawAllItems

print("WithdrawItemsHandler loaded successfully with PlayerDataManager!")
