-- ServerScriptService/SpeedrunServer

local ServerStorage   = game:GetService("ServerStorage")
local Players         = game:GetService("Players")
local SpeedrunHandler = require(ServerStorage.Modules.SpeedrunHandler)

-- Start a run
SpeedrunHandler.Remotes.StartSpeedrun.OnServerInvoke = function(player)
	return SpeedrunHandler.StartRun(player)
end

-- Reset/abandon a run
SpeedrunHandler.Remotes.ResetSpeedrun.OnServerInvoke = function(player)
	return SpeedrunHandler.ResetRun(player)
end

-- Get current speedrun state
SpeedrunHandler.Remotes.GetSpeedrunData.OnServerInvoke = function(player)
	return SpeedrunHandler.GetData(player)
end

-- Get leaderboard
SpeedrunHandler.Remotes.GetSpeedrunLeaderboard.OnServerInvoke = function(_, ageId)
	return SpeedrunHandler.GetLeaderboard(ageId)
end

-- ✅ NEW: Enter Speedrun Mode (snapshot + show controls)
SpeedrunHandler.Remotes.EnterSpeedrunMode.OnServerInvoke = function(player)
	return SpeedrunHandler.EnterSpeedrunMode(player)
end

-- ✅ NEW: Return to Main Plot (restore snapshot)
SpeedrunHandler.Remotes.ReturnToMainPlot.OnServerInvoke = function(player)
	return SpeedrunHandler.ReturnToMainPlot(player)
end

-- Resume run if player rejoins mid-run
Players.PlayerAdded:Connect(function(player)
	local dataLoaded = player:WaitForChild("DataLoaded", 30)
	if dataLoaded then
		SpeedrunHandler.ResumeRun(player)
	end
end)

print("✅ SpeedrunServer loaded")
