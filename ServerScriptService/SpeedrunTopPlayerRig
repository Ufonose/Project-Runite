-- ServerScriptService/SpeedrunTopPlayerRig
local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")
local ServerStorage = game:GetService("ServerStorage")

local CHECK_INTERVAL = 30
local SpeedrunStore = DataStoreService:GetOrderedDataStore("Speedrun_Total_v1")
local spawnPoint    = workspace:WaitForChild("Leaderboards"):WaitForChild("SpeedrunRigSpawnPoint")
local rigTemplate   = ServerStorage:WaitForChild("TopPlayerRig")
local danceAnim     = rigTemplate:WaitForChild("DanceAnimation")

local currentRig         = nil
local currentTopUserId   = nil

-- ── FORMAT TIME ───────────────────────────────────────────────────────────
local function formatTime(s)
	s = math.floor(math.abs(s))
	local h   = math.floor(s / 3600)
	local m   = math.floor((s % 3600) / 60)
	local sec = s % 60
	return h > 0
		and string.format("%d:%02d:%02d", h, m, sec)
		or  string.format("%d:%02d", m, sec)
end

-- ── NAMETAG ───────────────────────────────────────────────────────────────
local function createNametag(rig, name, timeSeconds)
	local head = rig:FindFirstChild("Head")
	if not head then return end

	local existing = head:FindFirstChild("TrophyGui")
	if existing then existing:Destroy() end

	local humanoid = rig:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid.DisplayName = name
	end

	local gui = Instance.new("BillboardGui")
	gui.Name = "TrophyGui"
	gui.Size = UDim2.new(4, 0, 2.5, 0)
	gui.StudsOffset = Vector3.new(0, 4, 0)
	gui.AlwaysOnTop = false
	gui.LightInfluence = 0
	gui.Parent = head

	local trophy = Instance.new("ImageLabel")
	trophy.Size = UDim2.new(0.25, 0, 0.6, 0)
	trophy.AnchorPoint = Vector2.new(0, 0.5)
	trophy.Position = UDim2.new(0, 0, 0.5, 0)
	trophy.BackgroundTransparency = 1
	trophy.Image = "rbxassetid://9722127533"
	trophy.ScaleType = Enum.ScaleType.Fit
	trophy.Parent = gui

	local timeLabel = Instance.new("TextLabel")
	timeLabel.Size = UDim2.new(0.7, 0, 0.6, 0)
	timeLabel.AnchorPoint = Vector2.new(0, 0.5)
	timeLabel.Position = UDim2.new(0.28, 0, 0.5, 0)
	timeLabel.BackgroundTransparency = 1
	timeLabel.Text = formatTime(timeSeconds)
	timeLabel.TextColor3 = Color3.fromRGB(80, 220, 120)
	timeLabel.TextScaled = true
	timeLabel.Font = Enum.Font.GothamBold
	timeLabel.TextXAlignment = Enum.TextXAlignment.Left
	timeLabel.Parent = gui

	local tc = Instance.new("UITextSizeConstraint", timeLabel)
	tc.MaxTextSize = 18
end

-- ── SPAWN RIG ─────────────────────────────────────────────────────────────
local function spawnRig(userId, timeSeconds)
	if currentRig then
		currentRig:Destroy()
		currentRig = nil
	end

	local rig = rigTemplate:Clone()
	rig.Name = "SpeedrunTopPlayerRig_Active"
	rig.Parent = workspace

	local hrp = rig:FindFirstChild("HumanoidRootPart")
	if hrp then
		hrp.CFrame = spawnPoint.CFrame + Vector3.new(0, spawnPoint.Size.Y / 2 + 3, 0)
		hrp.Anchored = true
	end

	for _, part in pairs(rig:GetDescendants()) do
		if part:IsA("BasePart") then
			part.CanCollide = false
		end
	end

	task.spawn(function()
		local humanoid = rig:FindFirstChildOfClass("Humanoid")
		if not humanoid then return end

		local ok, desc = pcall(function()
			return Players:GetHumanoidDescriptionFromUserIdAsync(userId)
		end)
		if ok and desc then
			pcall(function()
				humanoid:ApplyDescriptionResetAsync(desc)
			end)
		end

		local nameOk, name = pcall(function()
			return Players:GetNameFromUserIdAsync(userId)
		end)
		createNametag(rig, nameOk and name or "Unknown", timeSeconds)
	end)

	task.spawn(function()
		local humanoid = rig:FindFirstChildOfClass("Humanoid")
		if not humanoid then return end
		local animator = humanoid:WaitForChild("Animator", 5)
		if not animator then return end

		local anim = Instance.new("Animation")
		anim.AnimationId = danceAnim.AnimationId
		local track = animator:LoadAnimation(anim)
		track.Looped = true
		track:Play()
	end)

	currentRig = rig
	currentTopUserId = userId
end

-- ── FETCH TOP PLAYER ──────────────────────────────────────────────────────
-- Values are negative (fastest = most negative = rank #1 in descending sort)
local function fetchTopPlayer()
	local topUserId, topNegTime = nil, 0

	local ok, pages = pcall(function()
		return SpeedrunStore:GetSortedAsync(false, 1)
	end)
	if ok and pages then
		local data = pages:GetCurrentPage()
		if #data > 0 then
			topUserId  = tonumber(data[1].key)
			topNegTime = data[1].value -- negative number; more negative = faster
		end
	end

	-- Override with any online player who has a faster live PB
	-- SpeedrunPB is stored as a positive seconds value on the player
	for _, player in pairs(Players:GetPlayers()) do
		local pb = player:FindFirstChild("SpeedrunPB")
		if pb and pb.Value > 0 then
			local negVal = -pb.Value
			if negVal < topNegTime then -- more negative = faster
				topUserId  = player.UserId
				topNegTime = negVal
			end
		end
	end

	return topUserId, math.abs(topNegTime)
end

-- ── MAIN LOOP ─────────────────────────────────────────────────────────────
while true do
	local topUserId, timeSeconds = fetchTopPlayer()

	if topUserId and topUserId ~= currentTopUserId then
		spawnRig(topUserId, timeSeconds)
	end

	task.wait(CHECK_INTERVAL)
end
