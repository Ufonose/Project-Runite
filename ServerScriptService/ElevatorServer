local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local surfaceEvent = ReplicatedStorage.Events.TeleportToSurface
local caveEvent = ReplicatedStorage.Events.TeleportToCave
local surfaceElevators = workspace.SurfaceElevators
local caveElevators = workspace.CaveElevators

-- Track which players currently have a replication focus set
local focusActive = {}

local function getBasePlot(plot)
	return plot:FindFirstChild("BasePlot")
end

local function setFocus(player, focusPart)
	if focusActive[player] then return end -- already set, don't double-add
	pcall(function()
		player:AddReplicationFocus(focusPart)
		focusActive[player] = focusPart
	end)
end

local function clearFocus(player)
	local focusPart = focusActive[player]
	if not focusPart then return end -- never set, skip entirely
	focusActive[player] = nil
	pcall(function()
		player:RemoveReplicationFocus(focusPart)
	end)
end

-- Clean up when a player leaves
Players.PlayerRemoving:Connect(function(player)
	focusActive[player] = nil
end)

-- Cave --> Surface
surfaceEvent.OnServerEvent:Connect(function(player, targetPlotName)
	local setPlot = player:FindFirstChild("SetPlot")
	if not setPlot or not setPlot.Value then return end

	local plot = setPlot.Value
	local surfaceSpot = surfaceElevators:FindFirstChild(targetPlotName or plot.Name)

	if surfaceSpot and player.Character then
		local hrp = player.Character:FindFirstChild("HumanoidRootPart")
		if hrp then
			hrp.CFrame = surfaceSpot.CFrame + Vector3.new(0, 4, 0)

			local focusPart = getBasePlot(plot)
			if focusPart then
				setFocus(player, focusPart)
			end
		end
	end
end)

-- Surface --> Cave
caveEvent.OnServerEvent:Connect(function(player, targetPlotName)
	local caveSpot = caveElevators:FindFirstChild(targetPlotName)
	if caveSpot and player.Character then
		local hrp = player.Character:FindFirstChild("HumanoidRootPart")
		if hrp then
			hrp.CFrame = caveSpot.CFrame + Vector3.new(0, 4, 0)
			clearFocus(player)
		end
	end
end)
