-- ServerStorage/Modules/SpeedrunHandler
-- Handles all speedrun logic: start, reset, age splits, leaderboard saves

local ServerStorage    = game:GetService("ServerStorage")
local RepStorage       = game:GetService("ReplicatedStorage")
local DataStoreService = game:GetService("DataStoreService")
local Players          = game:GetService("Players")

local PlayerSession = require(ServerStorage.Modules.PlayerDataManager)
local ResearchData  = require(ServerStorage.Modules.ResearchData)

local SpeedrunHandler = {}

-- ============================================================
-- LEADERBOARD DATA STORES
-- Per-age stores hold SEGMENT time (time spent in that age only)
-- Total store holds full cumulative time
-- ============================================================
local LeaderboardStores = {
	[1]       = DataStoreService:GetOrderedDataStore("Speedrun_Age1_v1"),
	[2]       = DataStoreService:GetOrderedDataStore("Speedrun_Age2_v1"),
	[3]       = DataStoreService:GetOrderedDataStore("Speedrun_Age3_v1"),
	[4]       = DataStoreService:GetOrderedDataStore("Speedrun_Age4_v1"),
	["Total"] = DataStoreService:GetOrderedDataStore("Speedrun_Total_v1"),
}

-- ============================================================
-- REMOTE EVENTS
-- ============================================================
local Events = RepStorage:WaitForChild("Events")

local function getOrCreate(name, class)
	local existing = Events:FindFirstChild(name)
	if existing then return existing end
	local obj = Instance.new(class)
	obj.Name   = name
	obj.Parent = Events
	return obj
end

SpeedrunHandler.Remotes = {
	StartSpeedrun          = getOrCreate("StartSpeedrun",          "RemoteFunction"),
	ResetSpeedrun          = getOrCreate("ResetSpeedrun",          "RemoteFunction"),
	GetSpeedrunData        = getOrCreate("GetSpeedrunData",        "RemoteFunction"),
	GetSpeedrunLeaderboard = getOrCreate("GetSpeedrunLeaderboard", "RemoteFunction"),
	SpeedrunStarted   = getOrCreate("SpeedrunStarted",   "RemoteEvent"),
	SpeedrunAgeSplit  = getOrCreate("SpeedrunAgeSplit",  "RemoteEvent"), -- (ageId, segmentTime, cumulativeTime, isSegmentPB)
	SpeedrunCompleted = getOrCreate("SpeedrunCompleted", "RemoteEvent"), -- (totalTime, isTotalPB)
	SpeedrunReset     = getOrCreate("SpeedrunReset",     "RemoteEvent"),
}

-- ============================================================
-- HELPERS
-- ============================================================
local function getSpeedrun(player)
	local session = PlayerSession.Get(player)
	return session and session["Speedrun"]
end

local function getResearch(player)
	local session = PlayerSession.Get(player)
	return session and session["Research"]
end

-- Returns total elapsed seconds. StartTime == 0 means paused.
local function getElapsed(speedrun)
	if not speedrun.IsActive then return 0 end
	if speedrun.StartTime == 0 then
		return speedrun.ElapsedOnPause or 0
	end
	return os.time() - speedrun.StartTime
end

-- Compute segment time for an age from cumulative splits.
-- e.g. Age 2 segment = AgeSplits[2] - AgeSplits[1]
local function getSegmentTime(ageSplits, ageId, currentElapsed)
	local cumulative = currentElapsed or ageSplits[ageId]
	if not cumulative then return nil end
	local prevCumulative = ageId > 1 and ageSplits[ageId - 1] or 0
	return cumulative - prevCumulative
end

local function allResearchCompleted(completedObjectives)
	for _, obj in pairs(ResearchData.Objectives) do
		if not table.find(completedObjectives, obj.Id) then
			return false
		end
	end
	return true
end

local function isAgeCompleted(ageId, completedObjectives)
	local ageObjectives = ResearchData.GetObjectivesByAge(ageId)
	if #ageObjectives == 0 then return false end
	for _, obj in pairs(ageObjectives) do
		if not table.find(completedObjectives, obj.Id) then
			return false
		end
	end
	return true
end

-- ============================================================
-- RESET
-- ============================================================
local function performReset(player)
	local session = PlayerSession.Get(player)
	if not session then return false end

	local PLR_PLOT = player.SetPlot and player.SetPlot.Value
	if not PLR_PLOT then return false end

	local plrCash = ServerStorage.ServerLockedPlayerInfo.PlayerCash:FindFirstChild(player.Name)
	if not plrCash then return false end

	-- 1. Clear ores
	local oresDropped = PLR_PLOT:FindFirstChild("MiscInfo") and PLR_PLOT.MiscInfo:FindFirstChild("OresDropped")
	if oresDropped then oresDropped:ClearAllChildren() end

	-- 2. Clear placed items — preserve HotspotFurnace so SmeltOre keeps working
	for _, item in pairs(PLR_PLOT.PlacedItems:GetChildren()) do
		if item:GetAttribute("HotspotFurnace") then continue end
		local statsModule = item:FindFirstChild("ItemStats")
		if statsModule and statsModule:IsA("ModuleScript") then
			local ok, info = pcall(require, statsModule)
			if ok and info and info.ItemId == 3 then continue end
		end
		item:Destroy()
	end

	-- 2b. Restore CaveUnlocks and MinerHotspots from PlotTemplates
	local plotTemplates = ServerStorage:FindFirstChild("PlotTemplates")
	if plotTemplates then
		local template = plotTemplates:FindFirstChild(PLR_PLOT.Name)
		if template then
			local caveTemplate = template:FindFirstChild("CaveUnlocks")
			if caveTemplate then
				local existing = PLR_PLOT:FindFirstChild("CaveUnlocks")
				if existing then existing:Destroy() end
				caveTemplate:Clone().Parent = PLR_PLOT
			end
			local hotspotTemplate = template:FindFirstChild("MinerHotspots")
			if hotspotTemplate then
				local existing = PLR_PLOT:FindFirstChild("MinerHotspots")
				if existing then existing:Destroy() end
				hotspotTemplate:Clone().Parent = PLR_PLOT
			end
		end
	end

	-- 3. Wipe inventory amounts
	for _, data in pairs(session["Items"]) do
		if data then data["Amount"] = 0 end
	end

	-- 4. Re-lock research-unlocked machines
	for _, item in pairs(RepStorage.Items:GetChildren()) do
		local stats = item:FindFirstChild("ItemStats")
		if stats then
			local info = require(stats)
			local idStr = tostring(info.ItemId)
			local unlockedByResearch = ResearchData.GetUnlockingResearch(info.ItemId)
			if unlockedByResearch and session["Items"][idStr] then
				session["Items"][idStr]["Unlocked"] = false
			end
		end
	end

	-- 5. Restore starter items
	if session["Items"]["2"] then session["Items"]["2"]["Amount"] = 18 end
	if session["Items"]["7"] then session["Items"]["7"]["Amount"] = 4  end

	-- 6. Reset cash
	plrCash.Value = 400

	-- 6b. Reset barrier/hotspot records
	session["UnlockedBarriers"] = {}
	session["MinerHotspots"]    = { UnlockedHotspots = {} }

	-- 7. Reset research (keep ItemsCollected)
	local savedItemsCollected = session["Research"]["ItemsCollected"] or {}
	session["Research"] = {
		CompletedObjectives = {},
		ActiveObjectives    = {},
		ObjectiveProgress   = {},
		ItemsCollected      = savedItemsCollected,
	}

	-- 8. Reset research tokens
	local researchTokens = player:FindFirstChild("ResearchTokens")
	if researchTokens then researchTokens.Value = 0 end
	session["ResearchTokens"] = 0

	-- 9. Notify client
	RepStorage.Events.InventoryUpdate:FireClient(player)

	return true
end

-- ============================================================
-- LEADERBOARD SAVE
-- ============================================================
local saveCooldowns = {}

local function saveToLeaderboard(player, ageId, timeSeconds)
	local key = tostring(player.UserId) .. "_" .. tostring(ageId)
	local now = os.time()
	if saveCooldowns[key] and now - saveCooldowns[key] < 30 then return end
	saveCooldowns[key] = now

	local store = LeaderboardStores[ageId]
	if not store then return end

	pcall(function()
		store:UpdateAsync(tostring(player.UserId), function(existing)
			if existing == nil or timeSeconds < existing then
				return timeSeconds
			end
			return existing
		end)
	end)
end

-- ============================================================
-- FETCH LEADERBOARD
-- ============================================================
local function fetchLeaderboard(ageId)
	local store = LeaderboardStores[ageId]
	if not store then return {} end

	local results = {}
	local success, pages = pcall(function()
		return store:GetSortedAsync(true, 10)
	end)
	if not success then return {} end

	local ok, pageData = pcall(function() return pages:GetCurrentPage() end)
	if not ok then return {} end

	for _, entry in pairs(pageData) do
		local uid  = tonumber(entry.key)
		local name = "[Unknown]"
		pcall(function() name = Players:GetNameFromUserIdAsync(uid) end)
		table.insert(results, { name = name, time = entry.value, userId = uid })
	end

	return results
end

-- ============================================================
-- PUBLIC: Called from ResearchHandler.CompleteObjective
-- ============================================================
function SpeedrunHandler.OnObjectiveCompleted(player, objectiveId)
	local speedrun = getSpeedrun(player)
	if not speedrun or not speedrun.IsActive then return end

	local research = getResearch(player)
	if not research then return end

	local completedObjectives = research.CompletedObjectives
	local objective = ResearchData.GetObjective(objectiveId)
	if not objective then return end

	local ageId  = objective.Age
	local elapsed = getElapsed(speedrun) -- cumulative from run start

	if not speedrun.AgeSplits[ageId] and isAgeCompleted(ageId, completedObjectives) then
		-- Store cumulative split (needed to compute later segments and total)
		speedrun.AgeSplits[ageId] = elapsed

		-- Compute segment time (time spent only in this age)
		local segmentTime = getSegmentTime(speedrun.AgeSplits, ageId, elapsed)

		-- Track segment PB (BestAgeSplits now stores segment times)
		local existingSegPB = speedrun.BestAgeSplits[ageId]
		local isSegmentPB   = (existingSegPB == nil or segmentTime < existingSegPB)
		if isSegmentPB then
			speedrun.BestAgeSplits[ageId] = segmentTime
		end

		-- Save SEGMENT time to per-age leaderboard
		saveToLeaderboard(player, ageId, segmentTime)

		-- Notify client: (ageId, segmentTime, cumulativeTime, isSegmentPB)
		SpeedrunHandler.Remotes.SpeedrunAgeSplit:FireClient(player, ageId, segmentTime, elapsed, isSegmentPB)

		print(string.format("[Speedrun] %s — Age %d segment: %ds (cumulative: %ds)", player.Name, ageId, segmentTime, elapsed))

		-- Check if ALL ages done → run complete
		local allAgesDone = true
		for i = 1, #ResearchData.Ages do
			if not speedrun.AgeSplits[i] then
				allAgesDone = false
				break
			end
		end

		if allAgesDone then
			local totalTime     = elapsed
			local existingTotal = speedrun.BestTotalTime
			local isTotalPB     = (existingTotal == 0 or totalTime < existingTotal)
			if isTotalPB then
				speedrun.BestTotalTime = totalTime
			end

			speedrun.TotalRuns = speedrun.TotalRuns + 1
			speedrun.IsActive  = false

			-- Save cumulative total to Total leaderboard
			saveToLeaderboard(player, "Total", totalTime)
			SpeedrunHandler.Remotes.SpeedrunCompleted:FireClient(player, totalTime, isTotalPB)
			print(string.format("[Speedrun] %s finished in %ds total (PB: %s)", player.Name, totalTime, tostring(isTotalPB)))
		end
	end

	-- Permanently unlock speedrun mode if all research now complete
	if not speedrun.Unlocked and allResearchCompleted(completedObjectives) then
		speedrun.Unlocked = true
		print(string.format("[Speedrun] %s unlocked Speedrun mode!", player.Name))
		RepStorage.Events.MessageClient:FireClient(player, "screen", {
			["message"] = "🏁 Speedrun Mode Unlocked! You can now race through research!",
		})
	end
end

-- ============================================================
-- PUBLIC: Start a new run
-- ============================================================
function SpeedrunHandler.StartRun(player)
	local speedrun = getSpeedrun(player)
	if not speedrun then return false, "Data not loaded" end

	if not speedrun.Unlocked then
		local research = getResearch(player)
		if research and allResearchCompleted(research.CompletedObjectives) then
			speedrun.Unlocked = true
		end
	end

	if not speedrun.Unlocked then
		return false, "Complete all research objectives first to unlock Speedrun mode!"
	end

	if speedrun.IsActive then
		return false, "A run is already in progress. Reset it first."
	end

	local ok = performReset(player)
	if not ok then return false, "Failed to reset data. Try again." end

	speedrun.IsActive       = true
	speedrun.StartTime      = os.time()
	speedrun.ElapsedOnPause = 0
	speedrun.AgeSplits      = {}

	SpeedrunHandler.Remotes.SpeedrunStarted:FireClient(player)
	print(string.format("[Speedrun] %s started a new run", player.Name))

	return true, "Run started!"
end

-- ============================================================
-- PUBLIC: Reset/abandon a run
-- ============================================================
function SpeedrunHandler.ResetRun(player)
	local speedrun = getSpeedrun(player)
	if not speedrun then return false end
	if not speedrun.Unlocked then return false end

	local ok = performReset(player)
	if not ok then return false end

	speedrun.IsActive       = false
	speedrun.StartTime      = 0
	speedrun.ElapsedOnPause = 0
	speedrun.AgeSplits      = {}

	SpeedrunHandler.Remotes.SpeedrunReset:FireClient(player)
	print(string.format("[Speedrun] %s reset their run", player.Name))

	return true
end

-- ============================================================
-- PUBLIC: Pause run on player leave
-- ============================================================
function SpeedrunHandler.PauseRun(player)
	local speedrun = getSpeedrun(player)
	if not speedrun or not speedrun.IsActive then return end

	speedrun.ElapsedOnPause = getElapsed(speedrun)
	speedrun.StartTime      = 0
	print(string.format("[Speedrun] %s left — paused at %ds", player.Name, speedrun.ElapsedOnPause))
end

-- ============================================================
-- PUBLIC: Resume run on player rejoin
-- ============================================================
function SpeedrunHandler.ResumeRun(player)
	local speedrun = getSpeedrun(player)
	if not speedrun or not speedrun.IsActive then return end
	if speedrun.StartTime ~= 0 then return end

	speedrun.StartTime      = os.time() - (speedrun.ElapsedOnPause or 0)
	speedrun.ElapsedOnPause = 0
	print(string.format("[Speedrun] %s rejoined — resumed from %ds", player.Name, getElapsed(speedrun)))
end

-- ============================================================
-- PUBLIC: Return current state to client
-- ============================================================
function SpeedrunHandler.GetData(player)
	local speedrun = getSpeedrun(player)
	if not speedrun then return nil end

	if not speedrun.Unlocked then
		local research = getResearch(player)
		if research and allResearchCompleted(research.CompletedObjectives) then
			speedrun.Unlocked = true
			print(string.format("[Speedrun] Retroactively unlocked for %s", player.Name))
		end
	end

	-- Build segment times from cumulative splits for the client
	local segmentSplits = {}
	for i = 1, 4 do
		if speedrun.AgeSplits[i] then
			segmentSplits[i] = getSegmentTime(speedrun.AgeSplits, i)
		end
	end

	return {
		Unlocked       = speedrun.Unlocked,
		IsActive       = speedrun.IsActive,
		ElapsedTime    = getElapsed(speedrun),    -- total cumulative, for the main timer
		AgeSplits      = speedrun.AgeSplits,      -- cumulative, kept for reference
		SegmentSplits  = segmentSplits,           -- per-age segment times for display
		BestAgeSplits  = speedrun.BestAgeSplits,  -- best segment per age
		BestTotalTime  = speedrun.BestTotalTime,
		TotalRuns      = speedrun.TotalRuns,
	}
end

-- ============================================================
-- PUBLIC: Leaderboard
-- ============================================================
function SpeedrunHandler.GetLeaderboard(ageId)
	return fetchLeaderboard(ageId)
end

return SpeedrunHandler
