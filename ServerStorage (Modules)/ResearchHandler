-- ServerStorage/Modules/ResearchHandler
local ServerStorage = game:GetService("ServerStorage")
local RepStorage    = game:GetService("ReplicatedStorage")

local PlayerSession  = require(ServerStorage.Modules.PlayerDataManager)
local ResearchData   = require(ServerStorage.Modules.ResearchData)
local SpeedrunHandler = require(ServerStorage.Modules.SpeedrunHandler)

local ResearchHandler = {}

local SPEEDRUN_REQ_DIVISOR = 4

local function getEffectiveAmount(player, amount)
	local session = PlayerSession.Get(player)
	local inSpeedrun = session and session["Speedrun"] and session["Speedrun"].InSpeedrunMode == true
	if inSpeedrun then
		return math.max(1, math.round(amount / SPEEDRUN_REQ_DIVISOR))
	end
	return amount
end

ResearchHandler.GetEffectiveAmount = getEffectiveAmount

local function getItemNameFromId(itemId)
	for _, item in pairs(RepStorage.Items:GetChildren()) do
		local itemStats = item:FindFirstChild("ItemStats")
		if itemStats then
			local stats = require(itemStats)
			if stats.ItemId == itemId then
				return item.Name
			end
		end
	end
	return "Unknown Item"
end

function ResearchHandler.InitializePlayer(player)
	local session = PlayerSession.Get(player)
	if not session then return false end

	if not session["Research"] then
		session["Research"] = {
			CompletedObjectives = {},
			ActiveObjectives    = {},
			ObjectiveProgress   = {},
			ItemsCollected      = {},
		}
	end

	if not session["Research"]["ItemsCollected"] then
		session["Research"]["ItemsCollected"] = {}
	end

	return true
end

function ResearchHandler.TrackItemCollection(player, itemName, amount)
	if not ResearchHandler.InitializePlayer(player) then return end

	local session  = PlayerSession.Get(player)
	local research = session["Research"]

	if not research.ItemsCollected[itemName] then
		research.ItemsCollected[itemName] = 0
	end
	research.ItemsCollected[itemName] = research.ItemsCollected[itemName] + amount
end

function ResearchHandler.StartObjective(player, objectiveId)
	if not ResearchHandler.InitializePlayer(player) then return false end

	local session  = PlayerSession.Get(player)
	local research = session["Research"]
	local objective = ResearchData.GetObjective(objectiveId)

	if not objective then return false end
	if table.find(research.CompletedObjectives, objectiveId) then return false, "Already completed" end
	if table.find(research.ActiveObjectives,    objectiveId) then return false, "Already active" end

	if not ResearchData.CanStartObjective(objectiveId, research.CompletedObjectives) then
		return false, "Prerequisites not met"
	end

	table.insert(research.ActiveObjectives, objectiveId)
	research.ObjectiveProgress[tostring(objectiveId)] = {}

	for _, requirement in pairs(objective.Requirements) do
		research.ObjectiveProgress[tostring(objectiveId)][requirement.ItemName] = 0
	end

	-- Notify SpeedrunHandler for age timer tracking
	SpeedrunHandler.OnObjectiveStarted(player, objectiveId)
	return true
end

function ResearchHandler.DepositItem(player, objectiveId, itemName, amount)
	if not ResearchHandler.InitializePlayer(player) then return false end

	local session = PlayerSession.Get(player)
	local research = session["Research"]
	local objective = ResearchData.GetObjective(objectiveId)

	if not objective or not table.find(research.ActiveObjectives, objectiveId) then
		return false
	end

	local requirement = nil
	for _, req in pairs(objective.Requirements) do
		if req.ItemName == itemName then
			requirement = req
			break
		end
	end

	if not requirement then return false end

	local progressKey = tostring(objectiveId)
	local currentProgress = research.ObjectiveProgress[progressKey][itemName] or 0

	-- Apply 2x Research Boost (disabled during speedruns for fairness)
	local depositAmount = amount
	if _G.PlayerHasResearchBoost and _G.PlayerHasResearchBoost(player) then
		local speedrun = session["Speedrun"]
		local inSpeedrun = speedrun and speedrun.IsActive == true
		if not inSpeedrun then
			depositAmount = amount * 2
		end
	end
	
	-- ⭐ Apply Stonepeak Studios group benefit (5% chance to count as double)  <-- ADD HERE
	if _G.PlayerInStonepeak and _G.PlayerInStonepeak(player) then
		if math.random() < 0.05 then
			depositAmount = depositAmount * 2
		end
	end

	local newProgress = math.min(currentProgress + depositAmount, getEffectiveAmount(player, requirement.Amount))
	research.ObjectiveProgress[progressKey][itemName] = newProgress

	if ResearchHandler.CheckObjectiveComplete(player, objectiveId) then
		ResearchHandler.CompleteObjective(player, objectiveId)
	end

	return true, newProgress
end

function ResearchHandler.CheckObjectiveComplete(player, objectiveId)
	local session = PlayerSession.Get(player)
	if not session then return false end

	local research  = session["Research"]
	local objective = ResearchData.GetObjective(objectiveId)

	if not objective or not research.ObjectiveProgress[tostring(objectiveId)] then
		return false
	end

	for _, requirement in pairs(objective.Requirements) do
		local progress = research.ObjectiveProgress[tostring(objectiveId)][requirement.ItemName] or 0
		if progress < getEffectiveAmount(player, requirement.Amount) then
			return false
		end
	end

	return true
end

function ResearchHandler.CompleteObjective(player, objectiveId)
	local session = PlayerSession.Get(player)
	if not session then return false end

	local research  = session["Research"]
	local objective = ResearchData.GetObjective(objectiveId)

	if not objective then return false end

	table.insert(research.CompletedObjectives, objectiveId)

	local index = table.find(research.ActiveObjectives, objectiveId)
	if index then table.remove(research.ActiveObjectives, index) end

	local tokenReward = objective.Rewards.ResearchTokens or 0
	if tokenReward > 0 then
		player.ResearchTokens.Value = player.ResearchTokens.Value + tokenReward
	end

	local unlockedMachines = {}
	if objective.Rewards.UnlockMachines then
		for _, machineId in pairs(objective.Rewards.UnlockMachines) do
			local itemKey = tostring(machineId)
			if session["Items"][itemKey] then
				session["Items"][itemKey]["Unlocked"] = true
				table.insert(unlockedMachines, getItemNameFromId(machineId))
			end
		end
	end

	local notificationMessage = objective.Name .. " completed!"
	if tokenReward > 0 then
		notificationMessage = notificationMessage .. " +" .. tokenReward .. " Research Tokens"
	elseif #unlockedMachines > 0 then
		notificationMessage = notificationMessage .. " 🔓 Unlocked: " .. table.concat(unlockedMachines, ", ")
	elseif objective.Rewards.ResearchBonus then
		local bonus = objective.Rewards.ResearchBonus
		local bonusLabels = {
			IronMineSpeed    = "+%d%% Iron Mine Speed",
			CopperMineSpeed  = "+%d%% Copper Mine Speed",
			GoldMineSpeed    = "+%d%% Gold Mine Speed",
			CashBonus        = "+%d%% Cash Bonus",
			DoubleDropChance = "+%d%% Double Drop Chance",
		}
		local template = bonusLabels[bonus.Type]
		if template then
			notificationMessage = notificationMessage .. " ⚡ Bonus: " .. string.format(template, bonus.Value)
		end
	end

	RepStorage.Events.MessageClient:FireClient(player, "screen", {
		message = notificationMessage
	})

	-- Notify SpeedrunHandler for age splits and unlock detection
	SpeedrunHandler.OnObjectiveCompleted(player, objectiveId)
	
	-- Re-apply mine speed to existing miners if this objective gives a speed bonus
	if objective.Rewards.ResearchBonus then
		local mineTypeMap = {
			IronMineSpeed   = "Iron Mine",
			CopperMineSpeed = "Copper Mine",
			GoldMineSpeed   = "Gold Mine",
		}
		local mineType = mineTypeMap[objective.Rewards.ResearchBonus.Type]
		if mineType and _G.ReapplyMineSpeed then
			_G.ReapplyMineSpeed(player, mineType)
		end
	end

	-- Fire AllResearchCompleted when Ages 1-3 are all done (unlocks Legendary Mine)
	local completedAll3Ages = true
	for _, obj in pairs(ResearchData.Objectives) do
		if obj.Age <= 3 and not table.find(research.CompletedObjectives, obj.Id) then
			completedAll3Ages = false
			break
		end
	end
	if completedAll3Ages then
		RepStorage.Events.AllResearchCompleted:FireClient(player)
	end
	
	if objective.Rewards.ResearchBonus then
		local bonusEvent = RepStorage.Events:FindFirstChild("ResearchBonusUnlocked")
		if bonusEvent then
			bonusEvent:FireClient(player)
		end
	end
	
	-- ✅ Auto-start any objectives that just became available
	task.defer(ResearchHandler.AutoStartAvailableObjectives, player)

	return true
end

function ResearchHandler.GetPlayerResearch(player)
	ResearchHandler.InitializePlayer(player)
	local session = PlayerSession.Get(player)
	return session and session["Research"]
end

-- ============================================================
-- ✅ AUTO RESEARCH (Gamepass feature)
-- ============================================================
function ResearchHandler.AutoStartAvailableObjectives(player)
	-- Only run if the player owns the pass
	if not _G.PlayerHasAutoResearch or not _G.PlayerHasAutoResearch(player) then return end

	-- Only run if the player has the setting enabled
	local autoSetting = player.Settings:FindFirstChild("AutoResearch")
	if autoSetting and autoSetting.Value == false then return end

	local session = PlayerSession.Get(player)
	if not session then return end

	local available = ResearchData.GetAvailableObjectives(
		session["Research"].CompletedObjectives,
		session["Research"].ActiveObjectives
	)

	for _, objective in pairs(available) do
		ResearchHandler.StartObjective(player, objective.Id)
	end
end

-- Returns total research bonus (as a flat number, e.g. 10 for 10%) for a given upgradeId
function ResearchHandler.GetResearchBonus(player, upgradeId)
	local session = PlayerSession.Get(player)
	if not session then return 0 end
	local bonuses = ResearchData.GetTotalBonusesByType(session["Research"].CompletedObjectives)
	return bonuses[upgradeId] or 0
end

_G.GetResearchBonus = ResearchHandler.GetResearchBonus

-- Expose as global so GamepassHandler and ResearchServer can call it
_G.AutoStartAvailableObjectives = ResearchHandler.AutoStartAvailableObjectives

return ResearchHandler
