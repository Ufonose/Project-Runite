local ServerStorage = game:GetService("ServerStorage")
local ProfileStore = require(ServerStorage.Modules.ProfileStore)

local PlayerDataManager = {}

-- 1. DATA TEMPLATE (Fully reconciled with UpgradesData and Settings)
local DATA_TEMPLATE = {
	Money = 400,
	ResearchTokens = 0,
	Items = {},
	PlotItemPlaced = {},

	-- Player Stats
	Rebirth = 0,
	InvSort = "Newest",

	-- Settings
	settingHideResearch = false,
	settingMinesActive = true,
	settingNotificationSounds = true,
	settingOreLimit = 250,
	settingUISounds = true,

	-- Upgrades
	Upgrades = {
		["IronMineSpeed"] = 0,
		["CopperMineSpeed"] = 0,
		["GoldMineSpeed"] = 0,
		["ConveyorSpeed"] = 0,
		["CashBonus"] = 0,
		["GemDiscovery"] = 0,
		["DoubleDropChance"] = 0,
		["MovementSpeed"] = 0,
	},

	-- Research
	Research = {
		["CompletedObjectives"] = {},
		["ActiveObjectives"] = {},
		["ObjectiveProgress"] = {},
		["ItemsCollected"] = {},
	}
}

local PlayerStore = ProfileStore.New("Runite_vb2", DATA_TEMPLATE)
local ActiveProfiles = {}

-- ============================================================
-- CORE FUNCTIONS
-- ============================================================

function PlayerDataManager.Get(playerName)
	local profile = ActiveProfiles[playerName]
	return profile and profile.Data or nil
end

function PlayerDataManager.Load(player)
	local profile = PlayerStore:StartSessionAsync(tostring(player.UserId), {
		Cancel = function()
			return player.Parent ~= game:GetService("Players")
		end,
	})

	if profile ~= nil then
		-- Automatically fills in missing keys (like new Upgrades) for existing players
		profile:Reconcile() 

		profile.OnSessionEnd:Connect(function()
			ActiveProfiles[player.Name] = nil
			player:Kick("Data session ended - your progress has been saved.")
		end)

		if player.Parent == game:GetService("Players") then
			ActiveProfiles[player.Name] = profile
			return profile.Data
		else
			profile:EndSession()
		end
	else
		player:Kick("Failed to load data. Please rejoin.")
	end
end

function PlayerDataManager.Remove(playerName)
	local profile = ActiveProfiles[playerName]
	if profile then
		profile:EndSession()
		ActiveProfiles[playerName] = nil
	end
end

return PlayerDataManager
