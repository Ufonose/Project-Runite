local ServerStorage = game:GetService("ServerStorage")
local ProfileStore = require(ServerStorage.Modules.ProfileStore)

local PlayerDataManager = {}

local DATA_TEMPLATE = {
	Money = 400,
	TotalEarned = 0,
	ResearchTokens = 0,
	Items = {},
	PlotItemPlaced = {},

	Rebirth = 0,
	InvSort = "Newest",

	UnlockedBarriers = {},
	-- FIXED: was missing from template
	MinerHotspots = {
		UnlockedHotspots = {},
	},
	
	FurnaceHotspot = {
		Unlocked = true,
	},

	settingHideResearch = false,
	settingMinesActive = true,
	settingNotificationSounds = true,
	settingOreLimit = 250,
	settingUISounds = true,

	Upgrades = {
		["IronMineSpeed"] = 0,
		["CopperMineSpeed"] = 0,
		["GoldMineSpeed"] = 0,
		["ConveyorSpeed"] = 0,
		["CashBonus"] = 0,
		["GemDiscovery"] = 0,
		["DoubleDropChance"] = 0,
		["MovementSpeed"] = 0,
	},

	Research = {
		["CompletedObjectives"] = {},
		["ActiveObjectives"] = {},
		["ObjectiveProgress"] = {},
		["ItemsCollected"] = {},
	}
}

local PlayerStore = ProfileStore.New("Runite_v5", DATA_TEMPLATE)
local ActiveProfiles = {} -- FIXED: now keyed by UserId (number)

-- ============================================================
-- CORE FUNCTIONS
-- ============================================================

-- Pass the player object directly
function PlayerDataManager.Get(player)
	local profile = ActiveProfiles[player.UserId]
	return profile and profile.Data or nil
end

function PlayerDataManager.Load(player)
	local profile = PlayerStore:StartSessionAsync(tostring(player.UserId), {
		Cancel = function()
			return player.Parent ~= game:GetService("Players")
		end,
	})

	if profile ~= nil then
		profile:Reconcile()
		profile:AddUserId(player.UserId)

		profile.OnSessionEnd:Connect(function()
			ActiveProfiles[player.UserId] = nil
			if player.Parent == game:GetService("Players") then
				player:Kick("Data session ended - your progress has been saved.")
			end
		end)

		if player.Parent == game:GetService("Players") then
			ActiveProfiles[player.UserId] = profile -- FIXED: keyed by UserId
			return profile.Data
		else
			profile:EndSession()
		end
	else
		player:Kick("Failed to load data. Please rejoin.")
	end
end

-- Pass the player object directly
function PlayerDataManager.Remove(player)
	local profile = ActiveProfiles[player.UserId]
	if profile then
		profile:EndSession() -- OnSessionEnd handles the nil cleanup
	end
end

function PlayerDataManager.GetProfile(player)
	return ActiveProfiles[player.UserId]
end

return PlayerDataManager
