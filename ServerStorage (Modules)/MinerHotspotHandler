local ServerStorage = game:GetService("ServerStorage")
local Players = game:GetService("Players")

-- MODULES
local PlayerSession = require(ServerStorage.Modules.PlayerDataManager)

local MinerHotspotHandler = {}

-- Define all miner hotspots
MinerHotspotHandler.HotspotConfigs = {
	[1] = {Id = 1, MinerName = "Iron Mine 1", Cost = 4, Description = ""},
	[2] = {Id = 2, MinerName = "Iron Mine 2", Cost = 10, Description = ""},
	[3] = {Id = 3, MinerName = "Copper Mine 1", Cost = 1, Description = ""},
	[4] = {Id = 4, MinerName = "Copper Mine 2", Cost = 15, Description = ""},
	[5] = {Id = 5, MinerName = "Iron Mine 3", Cost = 110, Description = ""},
	[6] = {Id = 6, MinerName = "Copper Mine 3", Cost = 200, Description = ""},
	[7] = {Id = 7, MinerName = "Gold Mine 2", Cost = 90, Description = ""},
	[8] = {Id = 8, MinerName = "Gold Mine 3", Cost = 220, Description = ""},
	[9] = {Id = 9, MinerName = "Legendary Mine 1", CashCost = 25000, RequiresFullResearch = true, Description = ""},
	[10] = {Id = 10, MinerName = "Iron Mine 5", Cost = 0, Description = ""},
	[11] = {Id = 11, MinerName = "Copper Mine 4", Cost = 27, Description = ""},
	[12] = {Id = 12, MinerName = "Gold Mine 1", Cost = 1, Description = ""},
}

-- Initialize player's hotspot data in the Module
function MinerHotspotHandler.InitializePlayer(player)
	local session = PlayerSession.Get(player) -- FIXED
	if not session then
		warn("Player data session not found for", player.Name)
		return false
	end

	if not session["MinerHotspots"] then
		session["MinerHotspots"] = {
			UnlockedHotspots = {},
		}
	end
	return true
end

-- Check if a hotspot is unlocked
function MinerHotspotHandler.IsHotspotUnlocked(player, hotspotId)
	if not MinerHotspotHandler.InitializePlayer(player) then return false end
	local session = PlayerSession.Get(player) -- FIXED

	return table.find(session["MinerHotspots"].UnlockedHotspots, hotspotId) ~= nil
end

-- Unlock a hotspot
function MinerHotspotHandler.UnlockHotspot(player, hotspotId)
	if not MinerHotspotHandler.InitializePlayer(player) then
		return false, "Player data not loaded"
	end

	local session = PlayerSession.Get(player)
	local config = MinerHotspotHandler.HotspotConfigs[hotspotId]
	if not config then return false, "Invalid hotspot" end

	if MinerHotspotHandler.IsHotspotUnlocked(player, hotspotId) then
		return false, "Already unlocked"
	end

	-- Research gate check
	-- new:
	if config.RequiresFullResearch then
		local speedrun = session["Speedrun"]
		if not (speedrun and speedrun.InSpeedrunMode) then
			local ResearchData = require(ServerStorage.Modules.ResearchData)
			local research = session["Research"]
			if not research then return false, "Research not loaded" end
			for _, obj in pairs(ResearchData.Objectives) do
				if not table.find(research.CompletedObjectives, obj.Id) then
					return false, "Complete all research first"
				end
			end
		end
	end

	-- Payment
	if config.CashCost then
		local cashValue = ServerStorage.ServerLockedPlayerInfo.PlayerCash:FindFirstChild(player.Name)
		if not cashValue or cashValue.Value < config.CashCost then
			return false, "Not enough cash"
		end
		cashValue.Value -= config.CashCost
	else
		if player.ResearchTokens.Value < config.Cost then
			return false, "Not enough tokens"
		end
		player.ResearchTokens.Value -= config.Cost
	end

	table.insert(session["MinerHotspots"].UnlockedHotspots, hotspotId)
	MinerHotspotHandler.ActivateHotspot(player, hotspotId)
	return true
end

-- Activate a hotspot (spawn the real miner)
function MinerHotspotHandler.ActivateHotspot(player, hotspotId)
	local plot = player.SetPlot.Value
	if not plot then return end

	local hotspotFolder = plot:FindFirstChild("MinerHotspots")
	if not hotspotFolder then return end

	local hotspot = nil
	for _, h in pairs(hotspotFolder:GetChildren()) do
		if h:FindFirstChild("HotspotId") and h.HotspotId.Value == hotspotId then
			hotspot = h
			break
		end
	end

	if not hotspot then return end

	local config = MinerHotspotHandler.HotspotConfigs[hotspotId]
	local minerModel = RepStorage.Items:FindFirstChild(config.MinerName)
	if not minerModel then return end

	local activeMiner = minerModel:Clone()
	activeMiner:SetAttribute("HotspotMiner", true)
	activeMiner:SetAttribute("HotspotId", hotspotId)

	if activeMiner:FindFirstChild("Hitbox") then
		activeMiner.PrimaryPart = activeMiner.Hitbox
	end

	local positionPart = hotspot:FindFirstChild("Position")
	if positionPart then
		activeMiner:SetPrimaryPartCFrame(positionPart.CFrame)
	end

	activeMiner.Parent = plot.PlacedItems

	if activeMiner:FindFirstChild("ItemStats") then
		local itemStats = require(activeMiner.ItemStats)
		local layerValue = Instance.new("IntValue", activeMiner)
		layerValue.Name = "PlacementLayer"

		if type(itemStats.PlacementLayer) == "table" then
			layerValue.Value = itemStats.PlacementLayer[1]
			local layersString = Instance.new("StringValue", activeMiner)
			layersString.Name = "PlacementLayers"
			layersString.Value = table.concat(itemStats.PlacementLayer, ",")
		else
			layerValue.Value = itemStats.PlacementLayer or 1
		end
	end

	if activeMiner.PrimaryPart then
		activeMiner.PrimaryPart.Transparency = 1
		activeMiner.PrimaryPart.CanCollide = false
		activeMiner.PrimaryPart.Anchored = true
	end

	if _G.ApplyMinerUpgradesToItem then
		_G.ApplyMinerUpgradesToItem(player, activeMiner)
	end

	for _, descendant in pairs(activeMiner:GetDescendants()) do
		if descendant:IsA("Script") then
			descendant.Disabled = descendant:FindFirstChild("ForceDisabled")
		end
	end

	if hotspot:FindFirstChild("GhostMiner") then hotspot.GhostMiner:Destroy() end
	if hotspot:FindFirstChild("BuyButton") then hotspot.BuyButton:Destroy() end
end

-- Get player's hotspot data
function MinerHotspotHandler.GetPlayerHotspots(player)
	if not MinerHotspotHandler.InitializePlayer(player) then
		return {UnlockedHotspots = {}}
	end
	local session = PlayerSession.Get(player) -- FIXED
	return session["MinerHotspots"]
end

return MinerHotspotHandler
